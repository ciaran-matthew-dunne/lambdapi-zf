{
  "permissions": {
    "allow": [
      "Bash(lambdapi check:*)",
      "Bash(lambdapi parse:*)",
      "Bash(./check.py:*)",
      "Bash(python3 ./check.py:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(grep:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/lp_check.py\"",
            "timeout": 130,
            "statusMessage": "Type-checking Lambdapi…"
          }
        ]
      }
    ]
  }
}
