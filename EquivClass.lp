// EquivClass: Equivalence Relations and Quotient Constructions
//
// Isabelle source: EquivClass.thy
// Defines: refl_on, equiv, quotient, congruent, congruent2
// Proves: equivalence class lemmas, quotient properties

require open ZF.ZF_Base ZF.upair ZF.pair ZF.Trancl ZF.Perm;

// ===========================================================================
// Relational image of singleton вАФ r``{a} = {y | Pair(a,y) вИИ r}
// In Isabelle ZF: r``{a} is Image(r, {a})
// ===========================================================================

// rel_image_sing(r, a) = {y вИИ range(r) | Pair(a,y) вИИ r}
symbol rel_image_sing (r a : ѕД ќє) : ѕД ќє вЙФ
  Collect (range r) (ќї y, Pair a y вИИ r);

// rel_image_singI: Pair(a,b) вИИ r вЖТ b вИИ rel_image_sing(r, a)
opaque symbol rel_image_singI (a b r : ѕД ќє) :
  ѕА (Pair a b вИИ r) вЖТ ѕА (b вИИ rel_image_sing r a) вЙФ
begin
  assume a b r hab;
  refine CollectI b (range r) (ќї y, Pair a y вИИ r) (rangeI a b r hab) hab
end;

// rel_image_singD: b вИИ rel_image_sing(r, a) вЖТ Pair(a,b) вИИ r
opaque symbol rel_image_singD (a b r : ѕД ќє) :
  ѕА (b вИИ rel_image_sing r a) вЖТ ѕА (Pair a b вИИ r) вЙФ
begin
  assume a b r h;
  refine CollectD2 b (range r) (ќї y, Pair a y вИИ r) h
end;

// ===========================================================================
// Reflexive relation вАФ refl(A,r) вЙ° вИАxвИИA. Pair(x,x) вИИ r
// ===========================================================================

symbol refl_on (A r : ѕД ќє) : Prop вЙФ
  Ball A (ќї x, Pair x x вИИ r);

// ===========================================================================
// Equivalence relation вАФ equiv(A,r) вЙ° r вКЖ A√ЧA вИІ refl(A,r) вИІ sym(r) вИІ trans(r)
// ===========================================================================

symbol equiv (A r : ѕД ќє) : Prop вЙФ
  r вКЖ Sigma A (ќї _, A) вИІ refl_on A r вИІ sym r вИІ trans r;

// equiv projections
opaque symbol equiv_type (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (r вКЖ Sigma A (ќї _, A)) вЙФ
begin
  assume A r h;
  refine вИІвВСвВБ h
end;

opaque symbol equiv_refl (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (refl_on A r) вЙФ
begin
  assume A r h;
  refine вИІвВСвВБ (вИІвВСвВВ h)
end;

opaque symbol equiv_sym (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (sym r) вЙФ
begin
  assume A r h;
  refine вИІвВСвВБ (вИІвВСвВВ (вИІвВСвВВ h))
end;

opaque symbol equiv_trans (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (trans r) вЙФ
begin
  assume A r h;
  refine вИІвВСвВВ (вИІвВСвВВ (вИІвВСвВВ h))
end;

// ===========================================================================
// Quotient вАФ A//r = {r``{x} | x вИИ A}
// ===========================================================================

symbol quotient (A r : ѕД ќє) : ѕД ќє вЙФ
  RepFun A (ќї x, rel_image_sing r x);

// ===========================================================================
// Congruent вАФ congruent(r,b) вЙ° вИАy z. Pair(y,z) вИИ r вЖТ b(y) = b(z)
// ===========================================================================

symbol congruent (r : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє) : Prop вЙФ
  `вИА (y : ѕД ќє), `вИА (z : ѕД ќє), Pair y z вИИ r вЗТ b y = b z;

// ===========================================================================
// Congruent2 вАФ congruent2(r1,r2,b) вЙ° вИАy1 z1 y2 z2. ...
// ===========================================================================

symbol congruent2 (r1 r2 : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) : Prop вЙФ
  `вИА (y1 : ѕД ќє), `вИА (z1 : ѕД ќє), `вИА (y2 : ѕД ќє), `вИА (z2 : ѕД ќє),
    Pair y1 z1 вИИ r1 вЗТ Pair y2 z2 вИИ r2 вЗТ b y1 y2 = b z1 z2;

// ===========================================================================
// Section: Suppes Theorem 70
// equiv(A,r) iff converse(r) O r = r
// ===========================================================================

// sym_trans_comp_subset: sym(r) вЖТ trans(r) вЖТ converse(r) O r вКЖ r
opaque symbol sym_trans_comp_subset (r : ѕД ќє) :
  ѕА (sym r) вЖТ ѕА (trans r) вЖТ ѕА (rcomp (converse r) r вКЖ r) вЙФ
begin
  assume r hsym htrans p hp;
  // p вИИ rcomp(converse(r), r)
  // rcomp is Collect(Sigma(domain(r), ќї_. range(converse(r))), ...)
  // p must be in Sigma, so it's a pair
  have hSig : ѕА (p вИИ Sigma (domain r) (ќї _, range (converse r)))
    { refine CollectD1 p (Sigma (domain r) (ќї _, range (converse r)))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ r вИІ Pair y (snd q) вИИ converse r) hp };
  have hbex : ѕА (Bex (domain r) (ќї x, Bex (range (converse r)) (ќї y, p = Pair x y)))
    { refine SigmaE p (domain r) (ќї _, range (converse r)) hSig };
  refine вИГвВС hbex _;
  assume x hx;
  have hxdom : ѕА (x вИИ domain r) { refine вИІвВСвВБ hx };
  have hbex2 : ѕА (Bex (range (converse r)) (ќї y, p = Pair x y)) { refine вИІвВСвВВ hx };
  refine вИГвВС hbex2 _;
  assume z hz;
  have hzrng : ѕА (z вИИ range (converse r)) { refine вИІвВСвВБ hz };
  have hpeq : ѕА (p = Pair x z) { refine вИІвВСвВВ hz };
  // Now get the witness from rcomp
  have hfst_eq : ѕА (fst (Pair x z) = x) { refine fst_conv x z };
  have hsnd_eq : ѕА (snd (Pair x z) = z) { refine snd_conv x z };
  have hex : ѕА (`вИГ (y : ѕД ќє), Pair (fst p) y вИИ r вИІ Pair y (snd p) вИИ converse r)
    { refine CollectD2 p (Sigma (domain r) (ќї _, range (converse r)))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ r вИІ Pair y (snd q) вИИ converse r) hp };
  // Substitute p = Pair(x,z) to get fst p = x, snd p = z
  refine вИГвВС hex _;
  assume y hy;
  // Pair(fst p, y) вИИ r and Pair(y, snd p) вИИ converse(r)
  have h1 : ѕА (Pair (fst p) y вИИ r) { refine вИІвВСвВБ hy };
  have h2 : ѕА (Pair y (snd p) вИИ converse r) { refine вИІвВСвВВ hy };
  // fst p = x, snd p = z (via hpeq)
  have hfst_p : ѕА (fst p = x)
    { refine ind_eq hpeq (ќї q, fst q = x) hfst_eq };
  have hsnd_p : ѕА (snd p = z)
    { refine ind_eq hpeq (ќї q, snd q = z) hsnd_eq };
  // Pair(x,y) вИИ r
  have hxy : ѕА (Pair x y вИИ r)
    { refine ind_eq (eq_sym hfst_p) (ќї w, Pair w y вИИ r) h1 };
  // Pair(y,z) вИИ converse(r), so Pair(z,y) вИИ r
  have hyz_conv : ѕА (Pair y z вИИ converse r)
    { refine ind_eq (eq_sym hsnd_p) (ќї w, Pair y w вИИ converse r) h2 };
  have hzy : ѕА (Pair z y вИИ r) { refine converseD y z r hyz_conv };
  // By sym: Pair(y,z) вИИ r
  have hyz : ѕА (Pair y z вИИ r) { refine hsym z y hzy };
  // By trans: Pair(x,y) вИИ r вИІ Pair(y,z) вИИ r вЖТ Pair(x,z) вИИ r
  have hxz : ѕА (Pair x z вИИ r) { refine htrans x y z hxy hyz };
  rewrite hpeq;
  apply hxz
end;

// refl_comp_subset: refl(A,r) вЖТ r вКЖ A√ЧA вЖТ r вКЖ converse(r) O r
opaque symbol refl_comp_subset (A r : ѕД ќє) :
  ѕА (refl_on A r) вЖТ ѕА (r вКЖ Sigma A (ќї _, A)) вЖТ ѕА (r вКЖ rcomp (converse r) r) вЙФ
begin
  assume A r hrefl hsub p hp;
  // p вИИ r, and r вКЖ A√ЧA, so p = Pair(x,y) for some x вИИ A, y вИИ A
  have hpSig : ѕА (p вИИ Sigma A (ќї _, A)) { refine hsub p hp };
  have hbex : ѕА (Bex A (ќї x, Bex A (ќї y, p = Pair x y)))
    { refine SigmaE p A (ќї _, A) hpSig };
  refine вИГвВС hbex _;
  assume x hx;
  have hxA : ѕА (x вИИ A) { refine вИІвВСвВБ hx };
  have hbex2 : ѕА (Bex A (ќї y, p = Pair x y)) { refine вИІвВСвВВ hx };
  refine вИГвВС hbex2 _;
  assume y hy;
  have hyA : ѕА (y вИИ A) { refine вИІвВСвВБ hy };
  have hpeq : ѕА (p = Pair x y) { refine вИІвВСвВВ hy };
  // Pair(x,y) вИИ r
  have hxy : ѕА (Pair x y вИИ r) { refine ind_eq (eq_sym hpeq) (ќї q, q вИИ r) hp };
  // refl(A,r) вЖТ Pair(x,x) вИИ r
  have hxx : ѕА (Pair x x вИИ r) { refine hrefl x hxA };
  // converse(r): Pair(x,x) вИИ r вЖТ Pair(x,x) вИИ converse(r)
  have hxx_conv : ѕА (Pair x x вИИ converse r) { refine converseI x x r hxx };
  // rcomp(converse(r), r): Pair(x,y) вИИ r вИІ Pair(x,x) вИИ converse(r) вЖТ Pair(x,y) вИИ rcomp
  // rcompI: Pair(a,b) вИИ s вЖТ Pair(b,c) вИИ r вЖТ Pair(a,c) вИИ rcomp(r,s)
  // We need Pair(x,x) вИИ r (first arg to rcomp is 2nd relation)
  // rcomp(converse(r), r) means: вИГm. Pair(x,m) вИИ r вИІ Pair(m,y) вИИ converse(r)
  // Take m = x: Pair(x,x) вИИ r вЬУ and Pair(x,y) вИИ converse(r)
  // Wait: we need Pair(x,y) вИИ converse(r), i.e., Pair(y,x) вИИ r
  // Actually let's use m = y: Pair(x,y) вИИ r вЬУ and Pair(y,y) вИИ converse(r)
  // Pair(y,y) вИИ r since y вИИ A and refl
  have hyy : ѕА (Pair y y вИИ r) { refine hrefl y hyA };
  have hyy_conv : ѕА (Pair y y вИИ converse r) { refine converseI y y r hyy };
  // rcompI a b c r s: Pair(a,b) вИИ s вЖТ Pair(b,c) вИИ r вЖТ Pair(a,c) вИИ rcomp(r,s)
  // rcomp(converse(r), r): s=r, r=converse(r)
  // Need: Pair(x,y) вИИ r and Pair(y,y) вИИ converse(r) вЖТ Pair(x,y) вИИ rcomp(converse(r), r)
  have hres : ѕА (Pair x y вИИ rcomp (converse r) r)
    { refine rcompI x y y (converse r) r hxy hyy_conv };
  rewrite hpeq;
  apply hres
end;

// equiv_comp_eq: equiv(A,r) вЖТ converse(r) O r = r
opaque symbol equiv_comp_eq (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (rcomp (converse r) r = r) вЙФ
begin
  assume A r heq;
  refine subset_antisym (rcomp (converse r) r) r _ _
  { refine sym_trans_comp_subset r (equiv_sym A r heq) (equiv_trans A r heq) }
  { refine refl_comp_subset A r (equiv_refl A r heq) (equiv_type A r heq) }
end;

// comp_equivI: converse(r) O r = r вЖТ domain(r) = A вЖТ equiv(A,r)
opaque symbol comp_equivI (A r : ѕД ќє) :
  ѕА (rcomp (converse r) r = r) вЖТ ѕА (domain r = A) вЖТ ѕА (equiv A r) вЙФ
begin
  assume A r hcomp hdom;
  // Symmetry: converse(r)вИШr is inherently symmetric, and it equals r.
  have hsym : ѕА (sym r) {
    assume a b hab;
    have hin : ѕА (Pair a b вИИ rcomp (converse r) r)
      { refine ind_eq hcomp (ќї w, Pair a b вИИ w) hab };
    refine вИГвВС (rcompE_pair a b (converse r) r hin) _; assume y hy;
    have hby : ѕА (Pair b y вИИ r) { refine converseD y b r (вИІвВСвВВ hy) };
    have hya : ѕА (Pair y a вИИ converse r) { refine converseI a y r (вИІвВСвВБ hy) };
    refine ind_eq (eq_sym hcomp) (ќї w, Pair b a вИИ w)
      (rcompI b y a (converse r) r hby hya) };
  // Transitivity, using symmetry.
  have htrans : ѕА (trans r) {
    assume a b c hab hbc;
    have hbc_conv : ѕА (Pair b c вИИ converse r) { refine converseI c b r (hsym b c hbc) };
    refine ind_eq (eq_sym hcomp) (ќї w, Pair a c вИИ w)
      (rcompI a b c (converse r) r hab hbc_conv) };
  // Reflexivity on A = domain(r): each x has some вЯ®x,yвЯ©вИИr, so вЯ®x,xвЯ©вИИr by sym+trans.
  have hrefl : ѕА (refl_on A r) {
    assume x hxA;
    have hxdom : ѕА (x вИИ domain r) { refine ind_eq hdom (ќї w, x вИИ w) hxA };
    refine вИГвВС (domainE x r hxdom) _; assume y hxy;
    refine htrans x y x hxy (hsym x y hxy) };
  // r вКЖ A√ЧA: elements of r = converse(r)вИШr are pairs; both projections lie in domain(r)=A.
  have hsub : ѕА (r вКЖ Sigma A (ќї _, A)) {
    assume z hz;
    have hzc : ѕА (z вИИ rcomp (converse r) r) { refine ind_eq hcomp (ќї w, z вИИ w) hz };
    have hzS : ѕА (z вИИ Sigma (domain r) (ќї _, range (converse r)))
      { refine CollectD1 z (Sigma (domain r) (ќї _, range (converse r)))
          (ќї p, `вИГ (y : ѕД ќє), Pair (fst p) y вИИ r вИІ Pair y (snd p) вИИ converse r) hzc };
    refine вИГвВС (SigmaE z (domain r) (ќї _, range (converse r)) hzS) _; assume a haz;
    refine вИГвВС (вИІвВСвВВ haz) _; assume b hbz;
    have hzeq : ѕА (z = Pair a b) { refine вИІвВСвВВ hbz };
    have hab_r : ѕА (Pair a b вИИ r) { refine ind_eq (eq_sym hzeq) (ќї w, w вИИ r) hz };
    have haA : ѕА (a вИИ A) { refine ind_eq (eq_sym hdom) (ќї w, a вИИ w) (domainI a b r hab_r) };
    have hbA : ѕА (b вИИ A)
      { refine ind_eq (eq_sym hdom) (ќї w, b вИИ w) (domainI b a r (hsym a b hab_r)) };
    refine ind_eq hzeq (ќї w, w вИИ Sigma A (ќї _, A)) (SigmaI a b A (ќї _, A) haA hbA) };
  refine вИІбµҐ hsub (вИІбµҐ hrefl (вИІбµҐ hsym htrans))
end;

// ===========================================================================
// Equivalence classes
// ===========================================================================

// equiv_class_subset: sym(r) вЖТ trans(r) вЖТ Pair(a,b) вИИ r вЖТ r``{a} вКЖ r``{b}
opaque symbol equiv_class_subset (a b r : ѕД ќє) :
  ѕА (sym r) вЖТ ѕА (trans r) вЖТ ѕА (Pair a b вИИ r) вЖТ
  ѕА (rel_image_sing r a вКЖ rel_image_sing r b) вЙФ
begin
  assume a b r hsym htrans hab x hx;
  // x вИИ r``{a} means Pair(a,x) вИИ r
  have hax : ѕА (Pair a x вИИ r) { refine rel_image_singD a x r hx };
  // sym: Pair(a,b) вИИ r вЖТ Pair(b,a) вИИ r
  have hba : ѕА (Pair b a вИИ r) { refine hsym a b hab };
  // trans: Pair(b,a) вИИ r вЖТ Pair(a,x) вИИ r вЖТ Pair(b,x) вИИ r
  have hbx : ѕА (Pair b x вИИ r) { refine htrans b a x hba hax };
  refine rel_image_singI b x r hbx
end;

// equiv_class_eq: equiv(A,r) вЖТ Pair(a,b) вИИ r вЖТ r``{a} = r``{b}
opaque symbol equiv_class_eq (A a b r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (Pair a b вИИ r) вЖТ
  ѕА (rel_image_sing r a = rel_image_sing r b) вЙФ
begin
  assume A a b r heq hab;
  have hsym0 : ѕА (sym r) { refine equiv_sym A r heq };
  have htrans0 : ѕА (trans r) { refine equiv_trans A r heq };
  refine subset_antisym (rel_image_sing r a) (rel_image_sing r b) _ _
  { refine equiv_class_subset a b r hsym0 htrans0 hab }
  { // Pair(b,a) вИИ r by sym
    have hba : ѕА (Pair b a вИИ r) { refine hsym0 a b hab };
    refine equiv_class_subset b a r hsym0 htrans0 hba }
end;

// equiv_class_self: equiv(A,r) вЖТ a вИИ A вЖТ a вИИ r``{a}
opaque symbol equiv_class_self (A a r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (a вИИ A) вЖТ ѕА (a вИИ rel_image_sing r a) вЙФ
begin
  assume A a r heq haA;
  have hrefl0 : ѕА (refl_on A r) { refine equiv_refl A r heq };
  have haa : ѕА (Pair a a вИИ r) { refine hrefl0 a haA };
  refine rel_image_singI a a r haa
end;

// subset_equiv_class: equiv(A,r) вЖТ r``{b} вКЖ r``{a} вЖТ b вИИ A вЖТ Pair(a,b) вИИ r
opaque symbol subset_equiv_class (A a b r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (rel_image_sing r b вКЖ rel_image_sing r a) вЖТ ѕА (b вИИ A) вЖТ
  ѕА (Pair a b вИИ r) вЙФ
begin
  assume A a b r heq hsub hbA;
  // b вИИ r``{b} by refl
  have hb_self : ѕА (b вИИ rel_image_sing r b) { refine equiv_class_self A b r heq hbA };
  // b вИИ r``{a} by subset
  have hb_a : ѕА (b вИИ rel_image_sing r a) { refine hsub b hb_self };
  // Pair(a,b) вИИ r
  refine rel_image_singD a b r hb_a
end;

// eq_equiv_class: r``{a} = r``{b} вЖТ equiv(A,r) вЖТ b вИИ A вЖТ Pair(a,b) вИИ r
opaque symbol eq_equiv_class (A a b r : ѕД ќє) :
  ѕА (rel_image_sing r a = rel_image_sing r b) вЖТ ѕА (equiv A r) вЖТ ѕА (b вИИ A) вЖТ
  ѕА (Pair a b вИИ r) вЙФ
begin
  assume A a b r heqc heq hbA;
  refine subset_equiv_class A a b r heq
    (equalityD2 (rel_image_sing r a) (rel_image_sing r b) heqc) hbA
end;

// equiv_class_nondisjoint: equiv(A,r) вЖТ x вИИ r``{a} вИ© r``{b} вЖТ Pair(a,b) вИИ r
opaque symbol equiv_class_nondisjoint (A a b x r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (x вИИ Int (rel_image_sing r a) (rel_image_sing r b)) вЖТ
  ѕА (Pair a b вИИ r) вЙФ
begin
  assume A a b x r heq hx;
  have hsym0 : ѕА (sym r) { refine equiv_sym A r heq };
  have htrans0 : ѕА (trans r) { refine equiv_trans A r heq };
  have hxa : ѕА (x вИИ rel_image_sing r a)
    { refine вИІвВСвВБ (вИІвВСвВБ (Int_iff x (rel_image_sing r a) (rel_image_sing r b)) hx) };
  have hxb : ѕА (x вИИ rel_image_sing r b)
    { refine вИІвВСвВВ (вИІвВСвВБ (Int_iff x (rel_image_sing r a) (rel_image_sing r b)) hx) };
  // Pair(a,x) вИИ r and Pair(b,x) вИИ r
  have hax : ѕА (Pair a x вИИ r) { refine rel_image_singD a x r hxa };
  have hbx : ѕА (Pair b x вИИ r) { refine rel_image_singD b x r hxb };
  // sym: Pair(x,b) вИИ r
  have hxb2 : ѕА (Pair x b вИИ r) { refine hsym0 b x hbx };
  // trans: Pair(a,x) вИИ r вЖТ Pair(x,b) вИИ r вЖТ Pair(a,b) вИИ r
  refine htrans0 a x b hax hxb2
end;

// equiv_class_eq_iff: equiv(A,r) вЖТ (Pair(x,y) вИИ r вЗФ r``{x} = r``{y} вИІ x вИИ A вИІ y вИИ A)
opaque symbol equiv_class_eq_iff (A x y r : ѕД ќє) :
  ѕА (equiv A r) вЖТ
  ѕА (Pair x y вИИ r вЗФ (rel_image_sing r x = rel_image_sing r y вИІ x вИИ A вИІ y вИИ A)) вЙФ
begin
  assume A x y r heq;
  apply вИІбµҐ
  { assume hxy;
    have htype : ѕА (r вКЖ Sigma A (ќї _, A)) { refine equiv_type A r heq };
    have hpSig : ѕА (Pair x y вИИ Sigma A (ќї _, A)) { refine htype (Pair x y) hxy };
    have hbex : ѕА (Bex A (ќї a, Bex A (ќї b, Pair x y = Pair a b)))
      { refine SigmaE (Pair x y) A (ќї _, A) hpSig };
    // From Pair(x,y) вИИ Sigma(A, ќї_. A), get x вИИ A and y вИИ A
    have hxA : ѕА (x вИИ A)
    { refine вИГвВС hbex _;
      assume a ha;
      have haA : ѕА (a вИИ A) { refine вИІвВСвВБ ha };
      have hbex2 : ѕА (Bex A (ќї b, Pair x y = Pair a b)) { refine вИІвВСвВВ ha };
      refine вИГвВС hbex2 _;
      assume b hb;
      have hpeq : ѕА (Pair x y = Pair a b) { refine вИІвВСвВВ hb };
      have hxa : ѕА (x = a) { refine Pair_inject1 x y a b hpeq };
      rewrite hxa; apply haA };
    have hyA : ѕА (y вИИ A)
    { refine вИГвВС hbex _;
      assume a ha;
      have hbex2 : ѕА (Bex A (ќї b, Pair x y = Pair a b)) { refine вИІвВСвВВ ha };
      refine вИГвВС hbex2 _;
      assume b hb;
      have hbA : ѕА (b вИИ A) { refine вИІвВСвВБ hb };
      have hpeq : ѕА (Pair x y = Pair a b) { refine вИІвВСвВВ hb };
      have hyb : ѕА (y = b) { refine Pair_inject2 x y a b hpeq };
      rewrite hyb; apply hbA };
    apply вИІбµҐ
    { refine equiv_class_eq A x y r heq hxy }
    { apply вИІбµҐ hxA hyA } }
  { assume h;
    have heqc : ѕА (rel_image_sing r x = rel_image_sing r y) { refine вИІвВСвВБ h };
    have hyA : ѕА (y вИИ A) { refine вИІвВСвВВ (вИІвВСвВВ h) };
    refine eq_equiv_class A x y r heqc heq hyA }
end;

// eq_equiv_class_iff: equiv(A,r) вЖТ x вИИ A вЖТ y вИИ A вЖТ (r``{x} = r``{y} вЗФ Pair(x,y) вИИ r)
opaque symbol eq_equiv_class_iff (A x y r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (x вИИ A) вЖТ ѕА (y вИИ A) вЖТ
  ѕА (rel_image_sing r x = rel_image_sing r y вЗФ Pair x y вИИ r) вЙФ
begin
  assume A x y r heq hxA hyA;
  apply вИІбµҐ
  { assume heqc; refine eq_equiv_class A x y r heqc heq hyA }
  { assume hxy; refine equiv_class_eq A x y r heq hxy }
end;

// ===========================================================================
// Quotients
// ===========================================================================

// quotientI: x вИИ A вЖТ r``{x} вИИ A//r
opaque symbol quotientI (x A r : ѕД ќє) :
  ѕА (x вИИ A) вЖТ ѕА (rel_image_sing r x вИИ quotient A r) вЙФ
begin
  assume x A r hxA;
  refine RepFunI x A (ќї w, rel_image_sing r w) hxA
end;

// quotientE: X вИИ A//r вЖТ вИГxвИИA. X = r``{x}
opaque symbol quotientE (X A r : ѕД ќє) :
  ѕА (X вИИ quotient A r) вЖТ
  ѕА (Bex A (ќї x, X = rel_image_sing r x)) вЙФ
begin
  assume X A r hX;
  refine вИІвВСвВБ (RepFun_iff X A (ќї w, rel_image_sing r w)) hX
end;

// Union_quotient: equiv(A,r) вЖТ вЛГ(A//r) = A
opaque symbol Union_quotient (A r : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (Union (quotient A r) = A) вЙФ
begin
  assume A r heq;
  have htype : ѕА (r вКЖ Sigma A (ќї _, A)) { refine equiv_type A r heq };
  refine subset_antisym (Union (quotient A r)) A _ _
  { // вЛГ(A//r) вКЖ A: each class element is related to a class rep, hence in A.
    assume y hy;
    refine вИГвВС (UnionE y (quotient A r) hy) _; assume X hX;
    refine вИГвВС (quotientE X A r (вИІвВСвВБ hX)) _; assume x hxX;
    have hXeq : ѕА (X = rel_image_sing r x) { refine вИІвВСвВВ hxX };
    have hyRel : ѕА (y вИИ rel_image_sing r x)
      { refine ind_eq (eq_sym hXeq) (ќї w, y вИИ w) (вИІвВСвВВ hX) };
    have hSig : ѕА (Pair x y вИИ Sigma A (ќї _, A))
      { refine htype (Pair x y) (rel_image_singD x y r hyRel) };
    refine ind_eq (eq_sym (snd_conv x y)) (ќї w, w вИИ A) (SigmaD2 (Pair x y) A (ќї _, A) hSig) }
  { // A вКЖ вЛГ(A//r): x is in its own class, which is in the quotient.
    assume x hxA;
    refine UnionI x (rel_image_sing r x) (quotient A r)
      (equiv_class_self A x r heq hxA) (quotientI x A r hxA) }
end;

// quotient_disj: equiv(A,r) вЖТ X вИИ A//r вЖТ Y вИИ A//r вЖТ X = Y вИ® X вИ© Y вКЖ empty
opaque symbol quotient_disj (A r X Y : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (X вИИ quotient A r) вЖТ ѕА (Y вИИ quotient A r) вЖТ
  ѕА (X = Y вИ® Int X Y вКЖ empty) вЙФ
begin
  assume A r X Y heq hX hY;
  refine вИГвВС (quotientE X A r hX) _; assume a haX;
  have hXeq : ѕА (X = rel_image_sing r a) { refine вИІвВСвВВ haX };
  refine вИГвВС (quotientE Y A r hY) _; assume b hbY;
  have hYeq : ѕА (Y = rel_image_sing r b) { refine вИІвВСвВВ hbY };
  refine вИ®вВС (em (Int X Y = empty)) _ _
  { // disjoint
    assume hempty; refine вИ®бµҐвВВ _; rewrite hempty; refine subset_refl empty }
  { // a common element forces the two classes (hence X, Y) to coincide.
    assume hne; refine вИ®бµҐвВБ _;
    refine not_emptyE (Int X Y) (X = Y) hne _;
    assume z hz;
    have hz2 : ѕА (z вИИ Int (rel_image_sing r a) (rel_image_sing r b))
      { rewrite left hXeq; rewrite left hYeq; refine hz };
    have hcleq : ѕА (rel_image_sing r a = rel_image_sing r b)
      { refine equiv_class_eq A a b r heq (equiv_class_nondisjoint A a b z r heq hz2) };
    rewrite hXeq; rewrite hYeq; refine hcleq }
end;

// ===========================================================================
// Section: Defining Unary Operations upon Equivalence Classes
// ===========================================================================

// UN_equiv_class: equiv(A,r) вЖТ congruent(r,b) вЖТ a вИИ A вЖТ
//   вЛГ{b(x) | x вИИ r``{a}} = b(a)
// Note: вЛГ{b(x) | x вИИ S} is Union(RepFun(S, b))
opaque symbol UN_equiv_class (A r : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє) (a : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (congruent r b) вЖТ ѕА (a вИИ A) вЖТ
  ѕА (Union (RepFun (rel_image_sing r a) b) = b a) вЙФ
begin
  assume A r b a heq hcong haA;
  refine subset_antisym (Union (RepFun (rel_image_sing r a) b)) (b a) _ _
  { // every b(x) for x in the class equals b(a) (congruence), so the union вКЖ b(a).
    assume y hy;
    refine вИГвВС (UnionE y (RepFun (rel_image_sing r a) b) hy) _; assume S hS;
    refine вИГвВС (вИІвВСвВБ (RepFun_iff S (rel_image_sing r a) b) (вИІвВСвВБ hS)) _; assume x hx;
    have hSeq : ѕА (S = b x) { refine вИІвВСвВВ hx };
    have hbeq : ѕА (b a = b x) { refine hcong a x (rel_image_singD a x r (вИІвВСвВБ hx)) };
    have hy_bx : ѕА (y вИИ b x) { refine ind_eq (eq_sym hSeq) (ќї w, y вИИ w) (вИІвВСвВВ hS) };
    refine ind_eq hbeq (ќї w, y вИИ w) hy_bx }
  { // a is in its own class, so b(a) is one of the union'd sets.
    assume y hy;
    refine UnionI y (b a) (RepFun (rel_image_sing r a) b) hy
      (RepFunI a (rel_image_sing r a) b (equiv_class_self A a r heq haA)) }
end;

// UN_equiv_class_type: equiv(A,r) вЖТ congruent(r,b) вЖТ X вИИ A//r вЖТ
//   (вИАxвИИA. b(x) вИИ B) вЖТ вЛГ{b(x) | x вИИ X} вИИ B
opaque symbol UN_equiv_class_type (A r B : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє) (X : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (congruent r b) вЖТ ѕА (X вИИ quotient A r) вЖТ
  (ќ† (x : ѕД ќє), ѕА (x вИИ A) вЖТ ѕА (b x вИИ B)) вЖТ
  ѕА (Union (RepFun X b) вИИ B) вЙФ
begin
  assume A r B b X heq hcong hX hbB;
  refine вИГвВС (quotientE X A r hX) _; assume a haX;
  have haA : ѕА (a вИИ A) { refine вИІвВСвВБ haX };
  have hval : ѕА (Union (RepFun X b) = b a)
    { rewrite (вИІвВСвВВ haX); refine UN_equiv_class A r b a heq hcong haA };
  rewrite hval;
  refine hbB a haA
end;

// UN_equiv_class_inject: equiv(A,r) вЖТ congruent(r,b) вЖТ
//   вЛГ{b(x)|xвИИX} = вЛГ{b(y)|yвИИY} вЖТ X вИИ A//r вЖТ Y вИИ A//r вЖТ
//   (вИАx y. xвИИA вЖТ yвИИA вЖТ b(x)=b(y) вЖТ Pair(x,y)вИИr) вЖТ X = Y
opaque symbol UN_equiv_class_inject (A r : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє) (X Y : ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (congruent r b) вЖТ
  ѕА (Union (RepFun X b) = Union (RepFun Y b)) вЖТ
  ѕА (X вИИ quotient A r) вЖТ ѕА (Y вИИ quotient A r) вЖТ
  (ќ† (x : ѕД ќє), ќ† (y : ѕД ќє), ѕА (x вИИ A) вЖТ ѕА (y вИИ A) вЖТ ѕА (b x = b y) вЖТ ѕА (Pair x y вИИ r)) вЖТ
  ѕА (X = Y) вЙФ
begin
  assume A r b X Y heq hcong hunion hXq hYq hinj;
  refine вИГвВС (quotientE X A r hXq) _; assume a haX;
  have haA : ѕА (a вИИ A) { refine вИІвВСвВБ haX };
  have hXeq : ѕА (X = rel_image_sing r a) { refine вИІвВСвВВ haX };
  refine вИГвВС (quotientE Y A r hYq) _; assume c hcY;
  have hcA : ѕА (c вИИ A) { refine вИІвВСвВБ hcY };
  have hYeq : ѕА (Y = rel_image_sing r c) { refine вИІвВСвВВ hcY };
  have hXval : ѕА (Union (RepFun X b) = b a)
    { rewrite hXeq; refine UN_equiv_class A r b a heq hcong haA };
  have hYval : ѕА (Union (RepFun Y b) = b c)
    { rewrite hYeq; refine UN_equiv_class A r b c heq hcong hcA };
  // b a = вЛГ(X.b) = вЛГ(Y.b) = b c, so a and c are related, hence the classes coincide.
  have hbac : ѕА (b a = b c)
    { have h1 : ѕА (Union (RepFun X b) = b c) { rewrite hunion; refine hYval };
      rewrite left hXval; refine h1 };
  have hcleq : ѕА (rel_image_sing r a = rel_image_sing r c)
    { refine equiv_class_eq A a c r heq (hinj a c haA hcA hbac) };
  rewrite hXeq; rewrite hYeq; refine hcleq
end;

// ===========================================================================
// Section: Defining Binary Operations upon Equivalence Classes
// ===========================================================================

// congruent2_implies_congruent: equiv(A,r1) вЖТ congruent2(r1,r2,b) вЖТ a вИИ A вЖТ
//   congruent(r2, b(a))
opaque symbol congruent2_implies_congruent (A r1 r2 : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) (a : ѕД ќє) :
  ѕА (equiv A r1) вЖТ ѕА (congruent2 r1 r2 b) вЖТ ѕА (a вИИ A) вЖТ
  ѕА (congruent r2 (b a)) вЙФ
begin
  assume A r1 r2 b a heq hcong2 haA y z hyz;
  // congruent2: вИАy1 z1 y2 z2. Pair(y1,z1)вИИr1 вЖТ Pair(y2,z2)вИИr2 вЖТ b(y1,y2) = b(z1,z2)
  // Take y1=z1=a, y2=y, z2=z: need Pair(a,a) вИИ r1
  have haa : ѕА (Pair a a вИИ r1) { refine (equiv_refl A r1 heq) a haA };
  refine hcong2 a a y z haa hyz
end;

// congruent2_implies_congruent_UN: equiv(A1,r1) вЖТ equiv(A2,r2) вЖТ
//   congruent2(r1,r2,b) вЖТ a вИИ A2 вЖТ
//   congruent(r1, ќїx1. вЛГ{b(x1,x2) | x2 вИИ r2``{a}})
opaque symbol congruent2_implies_congruent_UN (A1 A2 r1 r2 : ѕД ќє)
  (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) (a : ѕД ќє) :
  ѕА (equiv A1 r1) вЖТ ѕА (equiv A2 r2) вЖТ ѕА (congruent2 r1 r2 b) вЖТ ѕА (a вИИ A2) вЖТ
  ѕА (congruent r1 (ќї x1, Union (RepFun (rel_image_sing r2 a) (ќї x2, b x1 x2)))) вЙФ
begin
  assume A1 A2 r1 r2 b a heq1 heq2 hcong2 haA2;
  assume y z hyz;
  // y, z вИИ A1.
  have hyzS : ѕА (Pair y z вИИ Sigma A1 (ќї _, A1)) { refine equiv_type A1 r1 heq1 (Pair y z) hyz };
  have hyA : ѕА (y вИИ A1)
    { refine ind_eq (eq_sym (fst_conv y z)) (ќї t, t вИИ A1)
        (SigmaD1 (Pair y z) A1 (ќї _, A1) hyzS) };
  have hzA : ѕА (z вИИ A1)
    { refine ind_eq (eq_sym (snd_conv y z)) (ќї t, t вИИ A1)
        (SigmaD2 (Pair y z) A1 (ќї _, A1) hyzS) };
  // Each inner union collapses (UN_equiv_class): вЛГx2вИИr2``{a}. b(y,x2) = b(y,a).
  have hfy : ѕА (Union (RepFun (rel_image_sing r2 a) (ќї x2, b y x2)) = b y a)
    { refine UN_equiv_class A2 r2 (ќї x2, b y x2) a heq2
        (congruent2_implies_congruent A1 r1 r2 b y heq1 hcong2 hyA) haA2 };
  have hfz : ѕА (Union (RepFun (rel_image_sing r2 a) (ќї x2, b z x2)) = b z a)
    { refine UN_equiv_class A2 r2 (ќї x2, b z x2) a heq2
        (congruent2_implies_congruent A1 r1 r2 b z heq1 hcong2 hzA) haA2 };
  // b(y,a) = b(z,a) by congruent2 with вЯ®a,aвЯ©вИИr2 (reflexivity).
  have hbeq : ѕА (b y a = b z a)
    { refine hcong2 y z a a hyz (equiv_refl A2 r2 heq2 a haA2) };
  rewrite hfy; rewrite hfz; refine hbeq
end;

// UN_equiv_class2: equiv(A1,r1) вЖТ equiv(A2,r2) вЖТ congruent2(r1,r2,b) вЖТ
//   a1 вИИ A1 вЖТ a2 вИИ A2 вЖТ
//   вЛГ{вЛГ{b(x1,x2) | x2 вИИ r2``{a2}} | x1 вИИ r1``{a1}} = b(a1,a2)
opaque symbol UN_equiv_class2 (A1 A2 r1 r2 : ѕД ќє)
  (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) (a1 a2 : ѕД ќє) :
  ѕА (equiv A1 r1) вЖТ ѕА (equiv A2 r2) вЖТ ѕА (congruent2 r1 r2 b) вЖТ
  ѕА (a1 вИИ A1) вЖТ ѕА (a2 вИИ A2) вЖТ
  ѕА (Union (RepFun (rel_image_sing r1 a1) (ќї x1,
    Union (RepFun (rel_image_sing r2 a2) (ќї x2, b x1 x2)))) = b a1 a2) вЙФ
begin
  assume A1 A2 r1 r2 b a1 a2 heq1 heq2 hcong2 ha1A1 ha2A2;
  // Collapse the outer union (function congruent on r1), then the inner one.
  have houter : ѕА (Union (RepFun (rel_image_sing r1 a1)
                     (ќї x1, Union (RepFun (rel_image_sing r2 a2) (ќї x2, b x1 x2))))
                   = Union (RepFun (rel_image_sing r2 a2) (ќї x2, b a1 x2)))
    { refine UN_equiv_class A1 r1
        (ќї x1, Union (RepFun (rel_image_sing r2 a2) (ќї x2, b x1 x2))) a1 heq1
        (congruent2_implies_congruent_UN A1 A2 r1 r2 b a2 heq1 heq2 hcong2 ha2A2) ha1A1 };
  rewrite houter;
  refine UN_equiv_class A2 r2 (ќї x2, b a1 x2) a2 heq2
    (congruent2_implies_congruent A1 r1 r2 b a1 heq1 hcong2 ha1A1) ha2A2
end;

// UN_equiv_class_type2: equiv(A,r) вЖТ congruent2(r,r,b) вЖТ
//   X1 вИИ A//r вЖТ X2 вИИ A//r вЖТ
//   (вИАx1вИИA. вИАx2вИИA. b(x1,x2) вИИ B) вЖТ
//   вЛГ{вЛГ{b(x1,x2)|x2вИИX2}|x1вИИX1} вИИ B
opaque symbol UN_equiv_class_type2 (A r B X1 X2 : ѕД ќє)
  (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (congruent2 r r b) вЖТ
  ѕА (X1 вИИ quotient A r) вЖТ ѕА (X2 вИИ quotient A r) вЖТ
  (ќ† (x1 : ѕД ќє), ќ† (x2 : ѕД ќє), ѕА (x1 вИИ A) вЖТ ѕА (x2 вИИ A) вЖТ ѕА (b x1 x2 вИИ B)) вЖТ
  ѕА (Union (RepFun X1 (ќї x1, Union (RepFun X2 (ќї x2, b x1 x2)))) вИИ B) вЙФ
begin
  assume A r B X1 X2 b heq hcong2 hX1 hX2 hbB;
  refine вИГвВС (quotientE X1 A r hX1) _; assume a1 ha1X;
  have ha1A : ѕА (a1 вИИ A) { refine вИІвВСвВБ ha1X };
  refine вИГвВС (quotientE X2 A r hX2) _; assume a2 ha2X;
  have ha2A : ѕА (a2 вИИ A) { refine вИІвВСвВБ ha2X };
  have hval : ѕА (Union (RepFun X1 (ќї x1, Union (RepFun X2 (ќї x2, b x1 x2)))) = b a1 a2)
    { rewrite (вИІвВСвВВ ha1X); rewrite (вИІвВСвВВ ha2X);
      refine UN_equiv_class2 A A r r b a1 a2 heq heq hcong2 ha1A ha2A };
  rewrite hval;
  refine hbB a1 a2 ha1A ha2A
end;

// congruent2I: equiv(A1,r1) вЖТ equiv(A2,r2) вЖТ
//   (вИАwвИИA2. вИАy z. Pair(y,z) вИИ r1 вЖТ b(y,w) = b(z,w)) вЖТ
//   (вИАwвИИA1. вИАy z. Pair(y,z) вИИ r2 вЖТ b(w,y) = b(w,z)) вЖТ
//   congruent2(r1,r2,b)
opaque symbol congruent2I (A1 A2 r1 r2 : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) :
  ѕА (equiv A1 r1) вЖТ ѕА (equiv A2 r2) вЖТ
  (ќ† (w : ѕД ќє), ѕА (w вИИ A2) вЖТ ќ† (y : ѕД ќє), ќ† (z : ѕД ќє), ѕА (Pair y z вИИ r1) вЖТ ѕА (b y w = b z w)) вЖТ
  (ќ† (w : ѕД ќє), ѕА (w вИИ A1) вЖТ ќ† (y : ѕД ќє), ќ† (z : ѕД ќє), ѕА (Pair y z вИИ r2) вЖТ ѕА (b w y = b w z)) вЖТ
  ѕА (congruent2 r1 r2 b) вЙФ
begin
  assume A1 A2 r1 r2 b heq1 heq2 hleft hright;
  assume y1 z1 y2 z2 h1 h2;
  // z1 вИИ A1 and y2 вИИ A2 (fields of the equivalence relations).
  have hz1A : ѕА (z1 вИИ A1)
    { refine ind_eq (eq_sym (snd_conv y1 z1)) (ќї w, w вИИ A1)
        (SigmaD2 (Pair y1 z1) A1 (ќї _, A1) (equiv_type A1 r1 heq1 (Pair y1 z1) h1)) };
  have hy2A : ѕА (y2 вИИ A2)
    { refine ind_eq (eq_sym (fst_conv y2 z2)) (ќї w, w вИИ A2)
        (SigmaD1 (Pair y2 z2) A2 (ќї _, A2) (equiv_type A2 r2 heq2 (Pair y2 z2) h2)) };
  // b y1 y2 = b z1 y2 (left congruence) = b z1 z2 (right congruence).
  have hstep1 : ѕА (b y1 y2 = b z1 y2) { refine hleft y2 hy2A y1 z1 h1 };
  rewrite hstep1; refine hright z1 hz1A y2 z2 h2
end;

// congruent2_commuteI: equiv(A,r) вЖТ
//   (вИАy z. yвИИA вЖТ zвИИA вЖТ b(y,z) = b(z,y)) вЖТ
//   (вИАw y z. wвИИA вЖТ Pair(y,z)вИИr вЖТ b(w,y) = b(w,z)) вЖТ
//   congruent2(r,r,b)
opaque symbol congruent2_commuteI (A r : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) :
  ѕА (equiv A r) вЖТ
  (ќ† (y : ѕД ќє), ќ† (z : ѕД ќє), ѕА (y вИИ A) вЖТ ѕА (z вИИ A) вЖТ ѕА (b y z = b z y)) вЖТ
  (ќ† (w : ѕД ќє), ќ† (y : ѕД ќє), ќ† (z : ѕД ќє), ѕА (w вИИ A) вЖТ ѕА (Pair y z вИИ r) вЖТ ѕА (b w y = b w z)) вЖТ
  ѕА (congruent2 r r b) вЙФ
begin
  assume A r b heq hcomm hcong;
  refine congruent2I A A r r b heq heq _ _
  { // left congruence from commutativity + right congruence.
    assume w hwA y z hyz;
    have hyzS : ѕА (Pair y z вИИ Sigma A (ќї _, A)) { refine equiv_type A r heq (Pair y z) hyz };
    have hyA : ѕА (y вИИ A)
      { refine ind_eq (eq_sym (fst_conv y z)) (ќї t, t вИИ A)
          (SigmaD1 (Pair y z) A (ќї _, A) hyzS) };
    have hzA : ѕА (z вИИ A)
      { refine ind_eq (eq_sym (snd_conv y z)) (ќї t, t вИИ A)
          (SigmaD2 (Pair y z) A (ќї _, A) hyzS) };
    // b y w = b w y = b w z = b z w
    rewrite (hcomm y w hyA hwA);
    rewrite (hcong w y z hwA hyz);
    refine hcomm w z hwA hzA }
  { assume w hwA y z hyz; refine hcong w y z hwA hyz }
end;

// congruent_commuteI: equiv(A,r) вЖТ Z вИИ A//r вЖТ
//   (вИАwвИИA. congruent(r, ќїz. b(w,z))) вЖТ
//   (вИАx y. xвИИA вЖТ yвИИA вЖТ b(y,x) = b(x,y)) вЖТ
//   congruent(r, ќїw. вЛГ{b(w,z) | z вИИ Z})
opaque symbol congruent_commuteI (A r Z : ѕД ќє) (b : ѕД ќє вЖТ ѕД ќє вЖТ ѕД ќє) :
  ѕА (equiv A r) вЖТ ѕА (Z вИИ quotient A r) вЖТ
  (ќ† (w : ѕД ќє), ѕА (w вИИ A) вЖТ ѕА (congruent r (ќї z, b w z))) вЖТ
  (ќ† (x : ѕД ќє), ќ† (y : ѕД ќє), ѕА (x вИИ A) вЖТ ѕА (y вИИ A) вЖТ ѕА (b y x = b x y)) вЖТ
  ѕА (congruent r (ќї w, Union (RepFun Z (ќї z, b w z)))) вЙФ
begin
  assume A r Z b heq hZ hcongw hcomm;
  refine вИГвВС (quotientE Z A r hZ) _; assume a haZ;
  have haA : ѕА (a вИИ A) { refine вИІвВСвВБ haZ };
  have hZeq : ѕА (Z = rel_image_sing r a) { refine вИІвВСвВВ haZ };
  assume y1 y2 h12;
  have h12S : ѕА (Pair y1 y2 вИИ Sigma A (ќї _, A)) { refine equiv_type A r heq (Pair y1 y2) h12 };
  have hy1A : ѕА (y1 вИИ A)
    { refine ind_eq (eq_sym (fst_conv y1 y2)) (ќї t, t вИИ A)
        (SigmaD1 (Pair y1 y2) A (ќї _, A) h12S) };
  have hy2A : ѕА (y2 вИИ A)
    { refine ind_eq (eq_sym (snd_conv y1 y2)) (ќї t, t вИИ A)
        (SigmaD2 (Pair y1 y2) A (ќї _, A) h12S) };
  // вЛГzвИИZ. b(w,z) collapses to b(w,a); reduce both sides.
  have hf1 : ѕА (Union (RepFun Z (ќї z, b y1 z)) = b y1 a)
    { rewrite hZeq; refine UN_equiv_class A r (ќї z, b y1 z) a heq (hcongw y1 hy1A) haA };
  have hf2 : ѕА (Union (RepFun Z (ќї z, b y2 z)) = b y2 a)
    { rewrite hZeq; refine UN_equiv_class A r (ќї z, b y2 z) a heq (hcongw y2 hy2A) haA };
  // b(y1,a) = b(a,y1) = b(a,y2) = b(y2,a) via commutativity + congruence of b(a,¬Ј).
  have hb : ѕА (b y1 a = b y2 a)
    { have e2 : ѕА (b a y1 = b a y2) { refine hcongw a haA y1 y2 h12 };
      rewrite (hcomm a y1 haA hy1A);
      rewrite e2;
      refine hcomm y2 a hy2A haA };
  rewrite hf1; rewrite hf2; refine hb
end;
