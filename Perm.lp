// Perm: Injections, Surjections, Bijections, Composition
//
// Isabelle source: Perm.thy
// The theory underlying permutation groups:
//   -- Composition of relations, the identity relation
//   -- Injections, surjections, bijections
//   -- Lemmas for the Schroeder-Bernstein Theorem

require open Stdlib.Set Stdlib.Prop Stdlib.FOL Stdlib.Eq
             Stdlib.Classic Stdlib.Impred Stdlib.HOL Stdlib.PropExt
             Stdlib.Epsilon;
require open ZF.ZF_Base ZF.upair ZF.pair ZF.equalities ZF.func;

// ===========================================================================
// Definitions
// ===========================================================================

// comp: composition of relations (Isabelle: r O s)
// Already defined as rcomp in pair.lp, but we re-export with Perm naming
// rcomp r s = {вЯ®x,zвЯ© вИИ domain(s)√Чrange(r) | вИГy. вЯ®x,yвЯ©вИИs вИІ вЯ®y,zвЯ©вИИr}

// id: identity function on A (Isabelle: id(A) = (ќїxвИИA. x))
// id_rel is defined in pair.lp as RepFun A (ќї x, Pair x x)
// Isabelle's id(A) = Lambda(A, ќї x. x) which is the same as RepFun A (ќї x, Pair x x)
// We define id_fun using Lambda for compatibility with fapply/Pi
symbol id_fun (A : ѕД ќє) : ѕД ќє вЙФ Lambda A (ќї x, x);

// inj: injective function space вАФ {f вИИ AвЖТB | вИАwвИИA. вИАxвИИA. f`w = f`x вЖТ w = x}
symbol inj (A B : ѕД ќє) : ѕД ќє вЙФ
  Collect (Pi A (ќї _, B))
    (ќї f, Ball A (ќї w, Ball A (ќї x, fapply f w = fapply f x вЗТ w = x)));

// surj: surjective function space вАФ {f вИИ AвЖТB | вИАyвИИB. вИГxвИИA. f`x = y}
symbol surj (A B : ѕД ќє) : ѕД ќє вЙФ
  Collect (Pi A (ќї _, B))
    (ќї f, Ball B (ќї y, Bex A (ќї x, fapply f x = y)));

// bij: bijective function space вАФ inj(A,B) вИ© surj(A,B)
symbol bij (A B : ѕД ќє) : ѕД ќє вЙФ Int (inj A B) (surj A B);

// ===========================================================================
// Section: Surjective Function Space
// ===========================================================================

// surj_is_fun: f вИИ surj(A,B) вЖТ f вИИ AвЖТB
opaque symbol surj_is_fun (f A B : ѕД ќє) :
  ѕА (f вИИ surj A B) вЖТ ѕА (f вИИ Pi A (ќї _, B)) вЙФ
begin
  assume f A B hf;
  refine CollectD1 f (Pi A (ќї _, B))
    (ќї g, Ball B (ќї y, Bex A (ќї x, fapply g x = y))) hf
end;

// surj_memD: f вИИ surj(A,B) вЖТ Ball B (ќї y, Bex A (ќї x, fapply f x = y))
opaque symbol surj_memD (f A B : ѕД ќє) :
  ѕА (f вИИ surj A B) вЖТ
  ѕА (Ball B (ќї y, Bex A (ќї x, fapply f x = y))) вЙФ
begin
  assume f A B hf;
  refine CollectD2 f (Pi A (ќї _, B))
    (ќї g, Ball B (ќї y, Bex A (ќї x, fapply g x = y))) hf
end;

// fun_is_surj: f вИИ Pi(A,B) вЖТ f вИИ surj(A, range(f))
// TODO: prove вАФ needs range_of_fun, apply_equality, domain_type
opaque symbol fun_is_surj (f A : ѕД ќє) (B : ѕД ќє вЖТ ѕД ќє) :
  ѕА (f вИИ Pi A B) вЖТ ѕА (f вИИ surj A (range f)) вЙФ
begin
  assume f A B hf;
  admit
end;

// surj_range: f вИИ surj(A,B) вЖТ range(f) = B
// TODO: prove вАФ needs apply_Pair, range_type
opaque symbol surj_range (f A B : ѕД ќє) :
  ѕА (f вИИ surj A B) вЖТ ѕА (range f = B) вЙФ
begin
  assume f A B hf;
  have hfun : ѕА (f вИИ Pi A (ќї _, B)) { refine surj_is_fun f A B hf };
  have hmem : ѕА (Ball B (ќї y, Bex A (ќї x, fapply f x = y))) { refine surj_memD f A B hf };
  have hsub : ѕА (f вКЖ Sigma A (ќї _, B))
    { refine PowD f (Sigma A (ќї _, B)) (CollectD1 f (Pow (Sigma A (ќї _, B))) _ hfun) };
  refine subset_antisym (range f) B _ _
  { // range f вКЖ B
    assume y hy;
    refine вИГвВС (rangeE y f hy) _; assume a hay;
    have hSig : ѕА (Pair a y вИИ Sigma A (ќї _, B))
      { refine subsetD f (Sigma A (ќї _, B)) (Pair a y) hsub hay };
    refine ind_eq (eq_sym (snd_conv a y)) (ќї w, w вИИ B) (SigmaD2 (Pair a y) A (ќї _, B) hSig) }
  { // B вКЖ range f
    assume y hy;
    refine вИГвВС (hmem y hy) _; assume x hx;
    have hfxy : ѕА (fapply f x = y) { refine вИІвВСвВВ hx };
    have hpair : ѕА (Pair x (fapply f x) вИИ f)
      { refine Pi_apply_Pair f x A (ќї _, B) hfun (вИІвВСвВБ hx) };
    refine rangeI x y f (ind_eq (eq_sym hfxy) (ќї w, Pair x w вИИ f) hpair) }
end;

// f_imp_surjective: f вИИ AвЖТB вЖТ (вИАyвИИB. d(y) вИИ A) вЖТ (вИАyвИИB. f`d(y) = y) вЖТ f вИИ surj(A,B)
opaque symbol f_imp_surjective (f A B : ѕД ќє) (d : ѕД ќє вЖТ ѕД ќє) :
  ѕА (f вИИ Pi A (ќї _, B)) вЖТ
  ѕА (Ball B (ќї y, d y вИИ A)) вЖТ
  ѕА (Ball B (ќї y, fapply f (d y) = y)) вЖТ
  ѕА (f вИИ surj A B) вЙФ
begin
  assume f A B d hfun hd hfd;
  refine CollectI f (Pi A (ќї _, B))
    (ќї g, Ball B (ќї y, Bex A (ќї x, fapply g x = y))) hfun _;
  assume y hyB;
  refine вИГбµҐ (d y) _;
  apply вИІбµҐ
  { refine hd y hyB }
  { refine hfd y hyB }
end;

// lam_surjective: (вИАxвИИA. c(x)вИИB) вЖТ (вИАyвИИB. d(y)вИИA) вЖТ (вИАyвИИB. c(d(y))=y) вЖТ
//   Lambda(A,c) вИИ surj(A,B)
opaque symbol lam_surjective (A B : ѕД ќє) (c d : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Ball A (ќї x, c x вИИ B)) вЖТ
  ѕА (Ball B (ќї y, d y вИИ A)) вЖТ
  ѕА (Ball B (ќї y, c (d y) = y)) вЖТ
  ѕА (Lambda A c вИИ surj A B) вЙФ
begin
  assume A B c d hc hd hcd;
  refine f_imp_surjective (Lambda A c) A B d _ _ _
  { // Lambda(A,c) вИИ AвЖТB
    refine lam_type A c (ќї _, B) hc }
  { // вИАyвИИB. d(y) вИИ A
    assume y hyB; refine hd y hyB }
  { // вИАyвИИB. fapply(Lambda(A,c), d(y)) = y
    assume y hyB;
    have hdA : ѕА (d y вИИ A) { refine hd y hyB };
    have hbeta : ѕА (fapply (Lambda A c) (d y) = c (d y))
      { refine beta A c (d y) hdA };
    rewrite hbeta;
    refine hcd y hyB }
end;

// ===========================================================================
// Section: Injective Function Space
// ===========================================================================

// inj_is_fun: f вИИ inj(A,B) вЖТ f вИИ AвЖТB
opaque symbol inj_is_fun (f A B : ѕД ќє) :
  ѕА (f вИИ inj A B) вЖТ ѕА (f вИИ Pi A (ќї _, B)) вЙФ
begin
  assume f A B hf;
  refine CollectD1 f (Pi A (ќї _, B))
    (ќї g, Ball A (ќї w, Ball A (ќї x, fapply g w = fapply g x вЗТ w = x))) hf
end;

// inj_memD: f вИИ inj(A,B) вЖТ вИАwвИИA. вИАxвИИA. f`w = f`x вЖТ w = x
opaque symbol inj_memD (f A B : ѕД ќє) :
  ѕА (f вИИ inj A B) вЖТ
  ѕА (Ball A (ќї w, Ball A (ќї x, fapply f w = fapply f x вЗТ w = x))) вЙФ
begin
  assume f A B hf;
  refine CollectD2 f (Pi A (ќї _, B))
    (ќї g, Ball A (ќї w, Ball A (ќї x, fapply g w = fapply g x вЗТ w = x))) hf
end;

// inj_apply_equality: f вИИ inj(A,B) вЖТ f`a = f`b вЖТ a вИИ A вЖТ b вИИ A вЖТ a = b
opaque symbol inj_apply_equality (f A B : ѕД ќє) (a b : ѕД ќє) :
  ѕА (f вИИ inj A B) вЖТ ѕА (fapply f a = fapply f b) вЖТ
  ѕА (a вИИ A) вЖТ ѕА (b вИИ A) вЖТ ѕА (a = b) вЙФ
begin
  assume f A B a b hinj heq haA hbA;
  have hcond : ѕА (Ball A (ќї w, Ball A (ќї x, fapply f w = fapply f x вЗТ w = x)))
    { refine inj_memD f A B hinj };
  refine hcond a haA b hbA heq
end;

// f_imp_injective: f вИИ AвЖТB вЖТ Ball A (ќї x, d(fapply f x) = x) вЖТ f вИИ inj(A,B)
opaque symbol f_imp_injective (f A B : ѕД ќє) (d : ѕД ќє вЖТ ѕД ќє) :
  ѕА (f вИИ Pi A (ќї _, B)) вЖТ
  ѕА (Ball A (ќї x, d (fapply f x) = x)) вЖТ
  ѕА (f вИИ inj A B) вЙФ
begin
  assume f A B d hfun hd;
  refine CollectI f (Pi A (ќї _, B))
    (ќї g, Ball A (ќї w, Ball A (ќї x, fapply g w = fapply g x вЗТ w = x))) hfun _;
  assume w hwA x hxA heq;
  // d(f`w) = w and d(f`x) = x
  have hdw : ѕА (d (fapply f w) = w) { refine hd w hwA };
  have hdx : ѕА (d (fapply f x) = x) { refine hd x hxA };
  // f`w = f`x, so d(f`w) = d(f`x), so w = x
  rewrite left hdw;
  rewrite heq;
  apply hdx
end;

// lam_injective: (вИАxвИИA. c(x)вИИB) вЖТ (вИАxвИИA. d(c(x)) = x) вЖТ Lambda(A,c) вИИ inj(A,B)
opaque symbol lam_injective (A B : ѕД ќє) (c d : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Ball A (ќї x, c x вИИ B)) вЖТ
  ѕА (Ball A (ќї x, d (c x) = x)) вЖТ
  ѕА (Lambda A c вИИ inj A B) вЙФ
begin
  assume A B c d hc hdc;
  refine f_imp_injective (Lambda A c) A B d _ _
  { refine lam_type A c (ќї _, B) hc }
  { assume x hxA;
    have hbeta : ѕА (fapply (Lambda A c) x = c x)
      { refine beta A c x hxA };
    rewrite hbeta;
    refine hdc x hxA }
end;

// ===========================================================================
// Section: Bijections
// ===========================================================================

// bij_is_inj: f вИИ bij(A,B) вЖТ f вИИ inj(A,B)
opaque symbol bij_is_inj (f A B : ѕД ќє) :
  ѕА (f вИИ bij A B) вЖТ ѕА (f вИИ inj A B) вЙФ
begin
  assume f A B hf;
  refine IntD1 f (inj A B) (surj A B) hf
end;

// bij_is_surj: f вИИ bij(A,B) вЖТ f вИИ surj(A,B)
opaque symbol bij_is_surj (f A B : ѕД ќє) :
  ѕА (f вИИ bij A B) вЖТ ѕА (f вИИ surj A B) вЙФ
begin
  assume f A B hf;
  refine IntD2 f (inj A B) (surj A B) hf
end;

// bij_is_fun: f вИИ bij(A,B) вЖТ f вИИ AвЖТB
opaque symbol bij_is_fun (f A B : ѕД ќє) :
  ѕА (f вИИ bij A B) вЖТ ѕА (f вИИ Pi A (ќї _, B)) вЙФ
begin
  assume f A B hf;
  have hinj : ѕА (f вИИ inj A B) { refine bij_is_inj f A B hf };
  refine inj_is_fun f A B hinj
end;

// bij_inverse_exists: f вИИ bij(A,B) вЖТ вИГgвИИBвЖТA. вИАaвИИA. g`(f`a)=a вИІ f`(g`(f`a))=f`a
// TODO: prove вАФ needs inj/surj properties
opaque symbol bij_inverse_exists (f A B : ѕД ќє) :
  ѕА (f вИИ bij A B) вЖТ
  ѕА (Bex (Pi B (ќї _, A)) (ќї g,
    Ball A (ќї a, fapply g (fapply f a) = a вИІ fapply f (fapply g (fapply f a)) = fapply f a))) вЙФ
begin
  assume f A B hf;
  admit
end;

// ===========================================================================
// Section: Composition helper lemmas (selected)
// ===========================================================================

// comp_mono: r вКЖ r' вЖТ s вКЖ s' вЖТ comp(r,s) вКЖ comp(r',s')
opaque symbol comp_mono (r r' s s' : ѕД ќє) :
  ѕА (r вКЖ r') вЖТ ѕА (s вКЖ s') вЖТ ѕА (rcomp r s вКЖ rcomp r' s') вЙФ
begin
  assume r r' s s' hr hs p hp;
  have hpS : ѕА (p вИИ Sigma (domain s) (ќї _, range r))
    { refine CollectD1 p (Sigma (domain s) (ќї _, range r))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ s вИІ Pair y (snd q) вИИ r) hp };
  have hpred : ѕА (`вИГ (y : ѕД ќє), Pair (fst p) y вИИ s вИІ Pair y (snd p) вИИ r)
    { refine CollectD2 p (Sigma (domain s) (ќї _, range r))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ s вИІ Pair y (snd q) вИИ r) hp };
  refine вИГвВС hpred _; assume y hy;
  have hsy' : ѕА (Pair (fst p) y вИИ s') { refine hs (Pair (fst p) y) (вИІвВСвВБ hy) };
  have hry' : ѕА (Pair y (snd p) вИИ r') { refine hr (Pair y (snd p)) (вИІвВСвВВ hy) };
  have hpeq : ѕА (Pair (fst p) (snd p) = p)
    { refine Pair_fst_snd p (domain s) (ќї _, range r) hpS };
  have hpS' : ѕА (p вИИ Sigma (domain s') (ќї _, range r'))
    { refine ind_eq (eq_sym hpeq) (ќї w, w вИИ Sigma (domain s') (ќї _, range r'))
        (SigmaI (fst p) (snd p) (domain s') (ќї _, range r')
          (domainI (fst p) y s' hsy') (rangeI y (snd p) r' hry')) };
  refine CollectI p (Sigma (domain s') (ќї _, range r'))
    (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ s' вИІ Pair y (snd q) вИИ r') hpS'
    (вИГбµҐ y (вИІбµҐ hsy' hry'))
end;

// rcomp_Int_subset: rcomp(rвИ©r', sвИ©s') вКЖ rcomp(r,s) вИ© rcomp(r',s')
opaque symbol rcomp_Int_subset (r r' s s' : ѕД ќє) :
  ѕА (rcomp (Int r r') (Int s s') вКЖ Int (rcomp r s) (rcomp r' s')) вЙФ
begin
  assume r r' s s' p hp;
  have hpS : ѕА (p вИИ Sigma (domain (Int s s')) (ќї _, range (Int r r')))
    { refine CollectD1 p (Sigma (domain (Int s s')) (ќї _, range (Int r r')))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ Int s s' вИІ Pair y (snd q) вИИ Int r r') hp };
  have hpred : ѕА (`вИГ (y : ѕД ќє), Pair (fst p) y вИИ Int s s' вИІ Pair y (snd p) вИИ Int r r')
    { refine CollectD2 p (Sigma (domain (Int s s')) (ќї _, range (Int r r')))
        (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ Int s s' вИІ Pair y (snd q) вИИ Int r r') hp };
  refine вИГвВС hpred _; assume y hy;
  have hs1 : ѕА (Pair (fst p) y вИИ s) { refine IntD1 (Pair (fst p) y) s s' (вИІвВСвВБ hy) };
  have hs2 : ѕА (Pair (fst p) y вИИ s') { refine IntD2 (Pair (fst p) y) s s' (вИІвВСвВБ hy) };
  have hr1 : ѕА (Pair y (snd p) вИИ r) { refine IntD1 (Pair y (snd p)) r r' (вИІвВСвВВ hy) };
  have hr2 : ѕА (Pair y (snd p) вИИ r') { refine IntD2 (Pair y (snd p)) r r' (вИІвВСвВВ hy) };
  have hpeq : ѕА (Pair (fst p) (snd p) = p)
    { refine Pair_fst_snd p (domain (Int s s')) (ќї _, range (Int r r')) hpS };
  refine IntI p (rcomp r s) (rcomp r' s') _ _
  { have hpS1 : ѕА (p вИИ Sigma (domain s) (ќї _, range r))
      { refine ind_eq (eq_sym hpeq) (ќї w, w вИИ Sigma (domain s) (ќї _, range r))
          (SigmaI (fst p) (snd p) (domain s) (ќї _, range r)
            (domainI (fst p) y s hs1) (rangeI y (snd p) r hr1)) };
    refine CollectI p (Sigma (domain s) (ќї _, range r))
      (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ s вИІ Pair y (snd q) вИИ r) hpS1
      (вИГбµҐ y (вИІбµҐ hs1 hr1)) }
  { have hpS2 : ѕА (p вИИ Sigma (domain s') (ќї _, range r'))
      { refine ind_eq (eq_sym hpeq) (ќї w, w вИИ Sigma (domain s') (ќї _, range r'))
          (SigmaI (fst p) (snd p) (domain s') (ќї _, range r')
            (domainI (fst p) y s' hs2) (rangeI y (snd p) r' hr2)) };
    refine CollectI p (Sigma (domain s') (ќї _, range r'))
      (ќї q, `вИГ (y : ѕД ќє), Pair (fst q) y вИИ s' вИІ Pair y (snd q) вИИ r') hpS2
      (вИГбµҐ y (вИІбµҐ hs2 hr2)) }
end;

// ===========================================================================
// Section: Basic converse and function utilities (used by EquivClass)
// ===========================================================================

opaque symbol converseI (a b r : ѕД ќє) :
  ѕА (Pair a b вИИ r) вЖТ ѕА (Pair b a вИИ converse r) вЙФ
begin
  assume a b r hab;
  have hcoll : ѕА (Pair a b вИИ Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
    { refine CollectI (Pair a b) r
        (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y)
        hab (вИГбµҐ a (вИГбµҐ b (eq_refl (Pair a b)))) };
  // RepFunI gives Pair(snd(Pair a b), fst(Pair a b)) вИИ converse r; rewrite the projections.
  have hrep : ѕА (Pair (snd (Pair a b)) (fst (Pair a b)) вИИ converse r)
    { refine RepFunI (Pair a b)
        (Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
        (ќї p, Pair (snd p) (fst p)) hcoll };
  have h1 : ѕА (Pair b (fst (Pair a b)) вИИ converse r)
    { refine ind_eq (eq_sym (snd_conv a b)) (ќї w, Pair w (fst (Pair a b)) вИИ converse r) hrep };
  refine ind_eq (eq_sym (fst_conv a b)) (ќї w, Pair b w вИИ converse r) h1
end;

// converseD: Pair(a,b) вИИ converse(r) вЖТ Pair(b,a) вИИ r
opaque symbol converseD (a b r : ѕД ќє) :
  ѕА (Pair a b вИИ converse r) вЖТ ѕА (Pair b a вИИ r) вЙФ
begin
  assume a b r h;
  have hbex : ѕА (Bex (Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
                     (ќї q, Pair a b = Pair (snd q) (fst q)))
    { refine вИІвВСвВБ (RepFun_iff (Pair a b)
        (Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
        (ќї p, Pair (snd p) (fst p))) h };
  refine вИГвВС hbex _;
  assume q hq;
  have hqC : ѕА (q вИИ Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
    { refine вИІвВСвВБ hq };
  have heq : ѕА (Pair a b = Pair (snd q) (fst q)) { refine вИІвВСвВВ hq };
  have hqr : ѕА (q вИИ r)
    { refine CollectD1 q r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y) hqC };
  have hpair : ѕА (`вИГ x : ѕД ќє, `вИГ y : ѕД ќє, q = Pair x y)
    { refine CollectD2 q r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y) hqC };
  refine вИГвВС hpair _; assume x hx; refine вИГвВС hx _; assume y hy;
  have hqeq : ѕА (q = Pair x y) { refine hy };
  have hqr2 : ѕА (Pair x y вИИ r) { refine ind_eq (eq_sym hqeq) (ќї z, z вИИ r) hqr };
  have hsndq : ѕА (snd q = y) { rewrite hqeq; refine snd_conv x y };
  have hfstq : ѕА (fst q = x) { rewrite hqeq; refine fst_conv x y };
  have hay : ѕА (a = snd q) { refine Pair_inject1 a b (snd q) (fst q) heq };
  have hbx : ѕА (b = fst q) { refine Pair_inject2 a b (snd q) (fst q) heq };
  have hay2 : ѕА (a = y) { rewrite hay; refine hsndq };
  have hbx2 : ѕА (b = x) { rewrite hbx; refine hfstq };
  have step1 : ѕА (Pair x a вИИ r) { refine ind_eq hay2 (ќї w, Pair x w вИИ r) hqr2 };
  refine ind_eq hbx2 (ќї w, Pair w a вИИ r) step1
end;

// converseE: a general element of converse(r) is a pair with the swapped pair in r.
//   z вИИ converse(r) вЖТ вИГx y. z = Pair(x,y) вИІ Pair(y,x) вИИ r
opaque symbol converseE (z r : ѕД ќє) :
  ѕА (z вИИ converse r) вЖТ
  ѕА (`вИГ (x : ѕД ќє), `вИГ (y : ѕД ќє), z = Pair x y вИІ Pair y x вИИ r) вЙФ
begin
  assume z r h;
  have hbex : ѕА (Bex (Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
                     (ќї q, z = Pair (snd q) (fst q)))
    { refine вИІвВСвВБ (RepFun_iff z
        (Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
        (ќї p, Pair (snd p) (fst p))) h };
  refine вИГвВС hbex _;
  assume q hq;
  have hqC : ѕА (q вИИ Collect r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y))
    { refine вИІвВСвВБ hq };
  have hzeq : ѕА (z = Pair (snd q) (fst q)) { refine вИІвВСвВВ hq };
  have hqr : ѕА (q вИИ r)
    { refine CollectD1 q r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y) hqC };
  have hpair : ѕА (`вИГ x : ѕД ќє, `вИГ y : ѕД ќє, q = Pair x y)
    { refine CollectD2 q r (ќї p, `вИГ x : ѕД ќє, `вИГ y : ѕД ќє, p = Pair x y) hqC };
  refine вИГвВС hpair _; assume a hx; refine вИГвВС hx _; assume b hy;
  have hqeq : ѕА (q = Pair a b) { refine hy };
  have hsndq : ѕА (snd q = b) { rewrite hqeq; refine snd_conv a b };
  have hfstq : ѕА (fst q = a) { rewrite hqeq; refine fst_conv a b };
  have hqr2 : ѕА (Pair a b вИИ r) { refine ind_eq (eq_sym hqeq) (ќї w, w вИИ r) hqr };
  // z = Pair(snd q, fst q) = Pair(b,a); witnesses x=b, y=a.
  refine вИГбµҐ b (вИГбµҐ a (вИІбµҐ _ hqr2));
  have h1 : ѕА (z = Pair b (fst q))
    { refine ind_eq (eq_sym hsndq) (ќї w, z = Pair w (fst q)) hzeq };
  refine ind_eq (eq_sym hfstq) (ќї w, z = Pair b w) h1
end;

// apply_equality: Pair(a,b) вИИ f вЖТ f вИИ Pi(A,B) вЖТ fapply(f,a) = b
opaque symbol apply_equality (a b f A : ѕД ќє) (B : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Pair a b вИИ f) вЖТ ѕА (f вИИ Pi A B) вЖТ ѕА (fapply f a = b) вЙФ
begin
  assume a b f A B hmem hfPi;
  refine function_apply_equality a b f hmem (Pi_function f A B hfPi)
end;

// domain_type: Pair(a,b) вИИ f вЖТ f вИИ Pi(A,B) вЖТ a вИИ A
opaque symbol domain_type (a b f A : ѕД ќє) (B : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Pair a b вИИ f) вЖТ ѕА (f вИИ Pi A B) вЖТ ѕА (a вИИ A) вЙФ
begin
  assume a b f A B hmem hfPi;
  have hPow : ѕА (f вИИ Pow (Sigma A B)) { refine CollectD1 f (Pow (Sigma A B)) _ hfPi };
  have hsub : ѕА (f вКЖ Sigma A B) { refine PowD f (Sigma A B) hPow };
  have hSig : ѕА (Pair a b вИИ Sigma A B) { refine subsetD f (Sigma A B) (Pair a b) hsub hmem };
  refine ind_eq (eq_sym (fst_conv a b)) (ќї w, w вИИ A) (SigmaD1 (Pair a b) A B hSig)
end;

// range_type: Pair(a,b) вИИ f вЖТ f вИИ Pi(A,B) вЖТ b вИИ B(a)
opaque symbol range_type (a b f A : ѕД ќє) (B : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Pair a b вИИ f) вЖТ ѕА (f вИИ Pi A B) вЖТ ѕА (b вИИ B a) вЙФ
begin
  assume a b f A B hmem hfPi;
  have hPow : ѕА (f вИИ Pow (Sigma A B)) { refine CollectD1 f (Pow (Sigma A B)) _ hfPi };
  have hsub : ѕА (f вКЖ Sigma A B) { refine PowD f (Sigma A B) hPow };
  have hSig : ѕА (Pair a b вИИ Sigma A B) { refine subsetD f (Sigma A B) (Pair a b) hsub hmem };
  have h2 : ѕА (snd (Pair a b) вИИ B (fst (Pair a b))) { refine SigmaD2 (Pair a b) A B hSig };
  have h3 : ѕА (b вИИ B (fst (Pair a b)))
    { refine ind_eq (eq_sym (snd_conv a b)) (ќї w, w вИИ B (fst (Pair a b))) h2 };
  refine ind_eq (eq_sym (fst_conv a b)) (ќї w, b вИИ B w) h3
end;

// ===========================================================================
// lam_bijective: a Lambda with a two-sided inverse is a bijection.
//   (вИАxвИИA. c x вИИ B) вЖТ (вИАyвИИB. d y вИИ A) вЖТ
//   (вИАxвИИA. d(c x) = x) вЖТ (вИАyвИИB. c(d y) = y) вЖТ Lambda(A,c) вИИ bij(A,B)
//   bij = inj вИ© surj, so combine lam_injective and lam_surjective.
// ===========================================================================
opaque symbol lam_bijective (A B : ѕД ќє) (c d : ѕД ќє вЖТ ѕД ќє) :
  ѕА (Ball A (ќї x, c x вИИ B)) вЖТ
  ѕА (Ball B (ќї y, d y вИИ A)) вЖТ
  ѕА (Ball A (ќї x, d (c x) = x)) вЖТ
  ѕА (Ball B (ќї y, c (d y) = y)) вЖТ
  ѕА (Lambda A c вИИ bij A B) вЙФ
begin
  assume A B c d hcB hdA hdc hcd;
  refine IntI (Lambda A c) (inj A B) (surj A B) _ _
  { refine lam_injective A B c d hcB hdc }
  { refine lam_surjective A B c d hcB hdA hcd }
end;
