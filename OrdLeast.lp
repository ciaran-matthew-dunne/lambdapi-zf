// OrdLeast.lp ‚Äî least-ordinal operator (Œº), Œµ-FREE.
//
// Provides `Least P` = the least ordinal satisfying P, defined via ZF.The
// (guarded definite description ‚Äî NO Hilbert Œµ, hence no choice), plus the two
// lemmas the hyperset development needs: `Least_equality` and `LeastI`.
//
// Kept deliberately minimal and fully proved (0 admits) so downstream code can
// import it without pulling in the whole of `Cardinal` (which is where
// Isabelle/ZF puts `Least`). Faithful to `isabelle-src/Cardinal.thy`.

require open ZF.ZF_Base ZF.upair ZF.Ordinal;

// Least(P) ‚â° THE i. Ord(i) ‚àß P(i) ‚àß (‚àÄ j. j < i ‚Üí ¬¨ P(j))
symbol Least (P : œÑ Œπ ‚Üí Prop) : œÑ Œπ ‚âî
  The (Œª i, Ord i ‚àß P i ‚àß (`‚àÄ (j : œÑ Œπ), lt j i ‚áí ¬¨ P j));

// Least_equality: if i witnesses P, is an ordinal, and nothing below it does,
// then the least such is exactly i. (Cardinal.thy Least_equality.)
opaque symbol Least_equality (P : œÑ Œπ ‚Üí Prop) (i : œÑ Œπ) :
  œÄ (P i) ‚Üí œÄ (Ord i) ‚Üí (ŒÝ (x : œÑ Œπ), œÄ (lt x i) ‚Üí œÄ (¬¨ P x)) ‚Üí
  œÄ (Least P = i) ‚âî
begin
  assume P i hPi hOi hmin;
  refine the_equality (Œª k, Ord k ‚àß P k ‚àß (`‚àÄ (j : œÑ Œπ), lt j k ‚áí ¬¨ P j)) i _ _
  { // i satisfies the guard predicate
    refine ‚àß·µ¢ hOi (‚àß·µ¢ hPi _);
    assume j hj; refine hmin j hj }
  { // uniqueness: any k satisfying the predicate equals i (ordinal trichotomy)
    assume k hk;
    have hOk : œÄ (Ord k) { refine ‚àß‚Çë‚ÇÅ hk };
    have hPk : œÄ (P k) { refine ‚àß‚Çë‚ÇÅ (‚àß‚Çë‚ÇÇ hk) };
    have hmink : œÄ (`‚àÄ (j : œÑ Œπ), lt j k ‚áí ¬¨ P j) { refine ‚àß‚Çë‚ÇÇ (‚àß‚Çë‚ÇÇ hk) };
    refine ‚à®‚Çë (Ord_linear i k hOi hOk) _ _
    { // i ‚àà k ‚áí lt i k ‚áí ¬¨ P i, contradicting P i
      assume hik; refine ‚ä•‚Çë (hmink i (ltI i k hik hOk) hPi) }
    { assume hd; refine ‚à®‚Çë hd _ _
      { assume hik; refine eq_sym hik }
      { // k ‚àà i ‚áí lt k i ‚áí ¬¨ P k, contradicting P k
        assume hki; refine ‚ä•‚Çë (hmin k (ltI k i hki hOi) hPk) } } }
end;

// LeastI: if some ordinal i satisfies P, then Least P satisfies P.
// (Cardinal.thy LeastI, by transfinite induction.)
opaque symbol LeastI (P : œÑ Œπ ‚Üí Prop) (i : œÑ Œπ) :
  œÄ (P i) ‚Üí œÄ (Ord i) ‚Üí œÄ (P (Least P)) ‚âî
begin
  assume P i hPi hOi;
  have hind : œÄ (P i ‚áí P (Least P))
    { refine trans_induct i (Œª i, P i ‚áí P (Least P)) hOi _;
      assume x hOx hIH hPx;
      refine ‚à®‚Çë (em (P (Least P))) _ _
      { assume hyes; refine hyes }
      { assume hno;
        // Nothing below x satisfies P: else the IH would give P(Least P).
        have hmin : ŒÝ (z : œÑ Œπ), œÄ (lt z x) ‚Üí œÄ (¬¨ P z)
          { assume z hzx hPz; refine hno (hIH z (ltD z x hzx) hPz) };
        have hLeq : œÄ (Least P = x) { refine Least_equality P x hPx hOx hmin };
        refine ind_eq hLeq (Œª w, P w) hPx } };
  refine hind hPi
end;
