// Finite: Finite Powerset Operator and Finite Function Space
//
// Isabelle source: Finite.thy (Lawrence C Paulson).
//   theory Finite imports Inductive Epsilon Nat
//
// Fin(A) and FiniteFun(A,B) are package-generated INDUCTIVE sets.  Here they
// are defined as least fixed points (lfp) of the monotone operators the
// Isabelle inductive package generates, and the intro/elim/induction rules
// are PROVED from the Knaster-Tarski theory in ZF.Fixedpt.

require open ZF.ZF_Base ZF.upair ZF.pair ZF.equalities ZF.func ZF.Fixedpt ZF.Trancl ZF.WF ZF.Perm ZF.Bool_ZF ZF.Sum ZF.Ordinal ZF.OrdQuant ZF.Nat_ZF ZF.QPair ZF.Epsilon ZF.Inductive;

// ===========================================================================
// Definitions  (consts Fin, FiniteFun + definition contents)
// ===========================================================================

// Fin(A): finite-powerset inductive set, lfp over domain Pow(A) of the
// operator generated by the Isabelle inductive package:
//   X ↦ {z ∈ Pow(A) | z = 0 ∨ (∃a b. z = cons(a,b) ∧ a ∈ A ∧ b ∈ X)}
symbol Fin (A : τ ι) : τ ι ≔
  lfp (Pow A) (λ X, Collect (Pow A) (λ z,
    z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ X)));

// FiniteFun(A,B) — Isabelle infix `A -||> B` — finite partial functions,
// lfp over domain Fin(A*B) of the package-generated operator:
//   X ↦ {z ∈ Fin(A*B) | z = 0 ∨
//        (∃a b h. z = cons(⟨a,b⟩,h) ∧ a ∈ A ∧ b ∈ B ∧ h ∈ X ∧ a ∉ domain(h))}
symbol FiniteFun (A B : τ ι) : τ ι ≔
  lfp (Fin (Sigma A (λ _, B))) (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
    z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (h : τ ι),
      z = cons (Pair a b) h ∧ a ∈ A ∧ b ∈ B ∧ h ∈ X ∧ a ∉ domain h)));

// contents(X) ≡ THE x. X = {x}
symbol contents (X : τ ι) : τ ι ≔ The (λ x, X = singleton x);

// ===========================================================================
// Private infrastructure
// ===========================================================================

// lfp induction principle (Fixedpt.thy `induct`), derived locally from the
// Knaster-Tarski lemmas in ZF.Fixedpt.
private opaque symbol lfp_induct_raw (D b : τ ι) (h : τ ι → τ ι) (P : τ ι → Prop) :
  π (b ∈ lfp D h) →
  π (bnd_mono D h) →
  (Π (x : τ ι), π (x ∈ h (Collect (lfp D h) P)) → π (P x)) →
  π (P b) ≔
begin
  assume D b h P hb hm hstep;
  have hmono : π (`∀ (W : τ ι), `∀ (X : τ ι), W ⊆ X ⇒ X ⊆ D ⇒ h W ⊆ h X)
    { refine ∧ₑ₂ (ind_eq (eq_sym (bnd_mono_def D h)) (λ p, p) hm) };
  have hunf : π (lfp D h = h (lfp D h)) { refine lfp_unfold D h hm };
  have hCsub : π (Collect (lfp D h) P ⊆ lfp D h)
    { refine Collect_subset (lfp D h) P };
  have hCD : π (Collect (lfp D h) P ⊆ D)
    { refine subset_trans (Collect (lfp D h) P) (lfp D h) D hCsub (lfp_subset D h) };
  // h(Collect(lfp,P)) is a pre-fixed point: membership via monotonicity +
  // unfold; the P-part is exactly the induction step.
  have hpre : π (h (Collect (lfp D h) P) ⊆ Collect (lfp D h) P)
    { assume x hx;
      have hhsub : π (h (Collect (lfp D h) P) ⊆ h (lfp D h))
        { refine hmono (Collect (lfp D h) P) (lfp D h) hCsub (lfp_subset D h) };
      have hxlfp : π (x ∈ lfp D h)
        { refine ind_eq hunf (λ w, x ∈ w) (hhsub x hx) };
      refine CollectI x (lfp D h) P hxlfp (hstep x hx) };
  have hlow : π (lfp D h ⊆ Collect (lfp D h) P)
    { refine lfp_lowerbound D (Collect (lfp D h) P) h hpre hCD };
  refine CollectD2 b (lfp D h) P (hlow b hb)
end;

// The Fin operator is bounded-monotone on Pow(A).
private opaque symbol Fin_bnd_mono (A : τ ι) :
  π (bnd_mono (Pow A) (λ X, Collect (Pow A) (λ z,
    z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ X)))) ≔
begin
  assume A;
  rewrite bnd_mono_def;
  apply ∧ᵢ
  { refine Collect_subset (Pow A) _ }
  { assume W X hWX hXD z hz;
    have hzD : π (z ∈ Pow A)
      { refine CollectD1 z (Pow A)
          (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), w = cons a b ∧ a ∈ A ∧ b ∈ W)) hz };
    have hd : π (z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ W))
      { refine CollectD2 z (Pow A)
          (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), w = cons a b ∧ a ∈ A ∧ b ∈ W)) hz };
    refine CollectI z (Pow A)
      (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), w = cons a b ∧ a ∈ A ∧ b ∈ X)) hzD _;
    refine ∨ₑ hd _ _
    { assume he; refine ∨ᵢ₁ he }
    { assume hex;
      refine ∃ₑ hex _;
      assume u hu;
      refine ∃ₑ hu _;
      assume v hv;
      refine ∨ᵢ₂ (∃ᵢ u (∃ᵢ v (∧ᵢ (∧ₑ₁ hv)
        (∧ᵢ (∧ₑ₁ (∧ₑ₂ hv)) (hWX v (∧ₑ₂ (∧ₑ₂ hv))))))) } }
end;

// The FiniteFun operator is bounded-monotone on Fin(A*B).
private opaque symbol FiniteFun_bnd_mono (A B : τ ι) :
  π (bnd_mono (Fin (Sigma A (λ _, B))) (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
    z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
      z = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ X ∧ a ∉ domain g)))) ≔
begin
  assume A B;
  rewrite bnd_mono_def;
  apply ∧ᵢ
  { refine Collect_subset (Fin (Sigma A (λ _, B))) _ }
  { assume W X hWX hXD z hz;
    have hzD : π (z ∈ Fin (Sigma A (λ _, B)))
      { refine CollectD1 z (Fin (Sigma A (λ _, B)))
          (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
            w = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ W ∧ a ∉ domain g)) hz };
    have hd : π (z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
        z = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ W ∧ a ∉ domain g))
      { refine CollectD2 z (Fin (Sigma A (λ _, B)))
          (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
            w = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ W ∧ a ∉ domain g)) hz };
    refine CollectI z (Fin (Sigma A (λ _, B)))
      (λ w, w = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
        w = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ X ∧ a ∉ domain g)) hzD _;
    refine ∨ₑ hd _ _
    { assume he; refine ∨ᵢ₁ he }
    { assume hex;
      refine ∃ₑ hex _;
      assume u hu;
      refine ∃ₑ hu _;
      assume v hv;
      refine ∃ₑ hv _;
      assume g hg;
      refine ∨ᵢ₂ (∃ᵢ u (∃ᵢ v (∃ᵢ g (∧ᵢ (∧ₑ₁ hg)
        (∧ᵢ (∧ₑ₁ (∧ₑ₂ hg))
          (∧ᵢ (∧ₑ₁ (∧ₑ₂ (∧ₑ₂ hg)))
            (∧ᵢ (hWX g (∧ₑ₁ (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ hg)))))
                (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ hg))))))))))) } }
end;

// --- generic set-theoretic helpers (Isabelle upair/equalities simp lemmas) ---

// cons_absorb: a ∈ B ⟹ cons(a,B) = B
private opaque symbol cons_absorb (a B : τ ι) :
  π (a ∈ B) → π (cons a B = B) ≔
begin
  assume a B ha;
  refine equality_iffI (cons a B) B _;
  assume w;
  apply ∧ᵢ
  { assume hw;
    refine ∨ₑ (∧ₑ₁ (cons_iff w a B) hw) _ _
    { assume hwa; refine ind_eq hwa (λ v, v ∈ B) ha }
    { assume hwB; refine hwB } }
  { assume hwB; refine consI2 w a B hwB }
end;

// cons_Diff: a ∈ B ⟹ cons(a, B - {a}) = B
private opaque symbol cons_Diff (a B : τ ι) :
  π (a ∈ B) → π (cons a (Diff B (singleton a)) = B) ≔
begin
  assume a B ha;
  refine equality_iffI (cons a (Diff B (singleton a))) B _;
  assume w;
  apply ∧ᵢ
  { assume hw;
    refine ∨ₑ (∧ₑ₁ (cons_iff w a (Diff B (singleton a))) hw) _ _
    { assume hwa; refine ind_eq hwa (λ v, v ∈ B) ha }
    { assume hwD; refine DiffD1 w B (singleton a) hwD } }
  { assume hwB;
    refine ∨ₑ (em (w = a)) _ _
    { assume hwa; refine ∧ₑ₂ (cons_iff w a (Diff B (singleton a))) (∨ᵢ₁ hwa) }
    { assume hne;
      refine consI2 w a (Diff B (singleton a)) (DiffI w B (singleton a) hwB _);
      assume hws;
      refine hne (∧ₑ₁ (singleton_iff w a) hws) } }
end;

// Diff_subset: A - B ⊆ A
private opaque symbol Diff_subset (A B : τ ι) :
  π (Diff A B ⊆ A) ≔
begin
  assume A B w hw;
  refine DiffD1 w A B hw
end;

// Diff_cons: b - cons(x,y) = (b - y) - {x}
private opaque symbol Diff_cons_eq (b x y : τ ι) :
  π (Diff b (cons x y) = Diff (Diff b y) (singleton x)) ≔
begin
  assume b x y;
  refine equality_iffI (Diff b (cons x y)) (Diff (Diff b y) (singleton x)) _;
  assume w;
  apply ∧ᵢ
  { assume hw;
    have hwb : π (w ∈ b) { refine DiffD1 w b (cons x y) hw };
    have hnc : π (w ∉ cons x y) { refine DiffD2 w b (cons x y) hw };
    refine DiffI w (Diff b y) (singleton x) _ _
    { refine DiffI w b y hwb _;
      assume hwy;
      refine hnc (consI2 w x y hwy) }
    { assume hws;
      refine hnc (∧ₑ₂ (cons_iff w x y) (∨ᵢ₁ (∧ₑ₁ (singleton_iff w x) hws))) } }
  { assume hw;
    have hwDby : π (w ∈ Diff b y) { refine DiffD1 w (Diff b y) (singleton x) hw };
    have hns : π (w ∉ singleton x) { refine DiffD2 w (Diff b y) (singleton x) hw };
    have hwb : π (w ∈ b) { refine DiffD1 w b y hwDby };
    have hny : π (w ∉ y) { refine DiffD2 w b y hwDby };
    refine DiffI w b (cons x y) hwb _;
    assume hc;
    refine ∨ₑ (∧ₑ₁ (cons_iff w x y) hc) _ _
    { assume hwx; refine hns (∧ₑ₂ (singleton_iff w x) hwx) }
    { assume hwy; refine hny hwy } }
end;

// Union(0) = 0
private opaque symbol Union_empty :
  π (Union empty = empty) ≔
begin
  refine equals0I (Union empty) _;
  assume u hu;
  refine ∃ₑ (UnionE u empty hu) _;
  assume Y hY;
  refine emptyE Y (∧ₑ₁ hY)
end;

// Union(cons(a,B)) = a ∪ Union(B)
private opaque symbol Union_cons (a B : τ ι) :
  π (Union (cons a B) = Un a (Union B)) ≔
begin
  assume a B;
  refine equality_iffI (Union (cons a B)) (Un a (Union B)) _;
  assume z;
  apply ∧ᵢ
  { assume hz;
    refine ∃ₑ (UnionE z (cons a B) hz) _;
    assume Y hY;
    refine ∨ₑ (∧ₑ₁ (cons_iff Y a B) (∧ₑ₁ hY)) _ _
    { assume hYa;
      refine UnI1 z a (Union B) (ind_eq (eq_sym hYa) (λ w, z ∈ w) (∧ₑ₂ hY)) }
    { assume hYB;
      refine UnI2 z a (Union B) (UnionI z Y B (∧ₑ₂ hY) hYB) } }
  { assume hz;
    refine ∨ₑ (UnE z a (Union B) hz) _ _
    { assume hza; refine UnionI z a (cons a B) hza (consI1 a B) }
    { assume hzU;
      refine ∃ₑ (UnionE z B hzU) _;
      assume Y hY;
      refine UnionI z Y (cons a B) (∧ₑ₂ hY) (consI2 Y a B (∧ₑ₁ hY)) } }
end;

// domain(0) = 0
private opaque symbol domain_empty :
  π (domain empty = empty) ≔
begin
  refine equals0I (domain empty) _;
  assume u hu;
  refine ∃ₑ (domainE u empty hu) _;
  assume v hv;
  refine emptyE (Pair u v) hv
end;

// domain(cons(⟨a,b⟩,r)) = cons(a, domain(r))
private opaque symbol domain_cons (a b r : τ ι) :
  π (domain (cons (Pair a b) r) = cons a (domain r)) ≔
begin
  assume a b r;
  refine equality_iffI (domain (cons (Pair a b) r)) (cons a (domain r)) _;
  assume u;
  apply ∧ᵢ
  { assume hu;
    refine ∃ₑ (domainE u (cons (Pair a b) r) hu) _;
    assume v hv;
    refine ∨ₑ (∧ₑ₁ (cons_iff (Pair u v) (Pair a b) r) hv) _ _
    { assume heq;
      refine ind_eq (Pair_inject1 u v a b heq) (λ w, w ∈ cons a (domain r))
        (consI1 a (domain r)) }
    { assume hm; refine consI2 u a (domain r) (domainI u v r hm) } }
  { assume hu;
    refine ∨ₑ (∧ₑ₁ (cons_iff u a (domain r)) hu) _ _
    { assume hua;
      refine ind_eq hua (λ w, w ∈ domain (cons (Pair a b) r))
        (domainI a b (cons (Pair a b) r) (consI1 (Pair a b) r)) }
    { assume hud;
      refine ∃ₑ (domainE u r hud) _;
      assume v hv;
      refine domainI u v (cons (Pair a b) r) (consI2 (Pair u v) (Pair a b) r hv) } }
end;

// domain(restrict(f,A)) ⊆ A
private opaque symbol domain_restrict_sub (f A : τ ι) :
  π (domain (restrict f A) ⊆ A) ≔
begin
  assume f A u hu;
  refine ∃ₑ (domainE u (restrict f A) hu) _;
  assume v hv;
  have hbex : π (Bex A (λ w, `∃ (t : τ ι), Pair u v = Pair w t))
    { refine ∧ₑ₂ (restrictE (Pair u v) f A hv) };
  refine ∃ₑ hbex _;
  assume w hw;
  refine ∃ₑ (∧ₑ₂ hw) _;
  assume t ht;
  refine ind_eq (Pair_inject1 u v w t ht) (λ s, s ∈ A) (∧ₑ₁ hw)
end;

// --- function-space helpers (Isabelle func.thy lemmas not yet in func.lp) ---

// f ∈ Pi(0,B) ⟹ f = 0
private opaque symbol fun_empty_eq (f : τ ι) (B : τ ι → τ ι) :
  π (f ∈ Pi empty B) → π (f = empty) ≔
begin
  assume f B hf;
  refine equals0I f _;
  assume p hp;
  refine ∃ₑ (SigmaE p empty B (Pi_subset_Sigma f empty B hf p hp)) _;
  assume u hu;
  refine emptyE u (∧ₑ₁ hu)
end;

// 0 ∈ Pi(0,B)
private opaque symbol empty_funI (B : τ ι → τ ι) :
  π (empty ∈ Pi empty B) ≔
begin
  assume B;
  rewrite Pi_def;
  refine CollectI empty (Pow (Sigma empty B)) (λ g, empty ⊆ domain g ∧ function g)
    (Pow_bottom (Sigma empty B)) _;
  apply ∧ᵢ
  { refine empty_subset (domain empty) }
  { rewrite function_def;
    assume x y yp h1 h2; refine ⊥ₑ (emptyE (Pair x y) h1) }
end;

// fun_extend3 (func.thy): f ∈ A->B ⟹ c ∉ A ⟹ b ∈ B ⟹ cons(⟨c,b⟩,f) ∈ cons(c,A)->B
private opaque symbol fun_extend3 (f A B c b : τ ι) :
  π (f ∈ Pi A (λ _, B)) → π (c ∉ A) → π (b ∈ B) →
  π (cons (Pair c b) f ∈ Pi (cons c A) (λ _, B)) ≔
begin
  assume f A B c b hf hcA hbB;
  have hsubS : π (f ⊆ Sigma A (λ _, B)) { refine Pi_subset_Sigma f A (λ _, B) hf };
  have hAdom : π (A ⊆ domain f)
    { refine ∧ₑ₂ (∧ₑ₂ (∧ₑ₁ (Pi_iff f A (λ _, B)) hf)) };
  have hfun : π (function f) { refine Pi_function f A (λ _, B) hf };
  have hmemD : π (`∀ (u : τ ι), `∀ (v : τ ι), Pair u v ∈ f ⇒ u ∈ A)
    { assume u v huv;
      have hfst : π (fst (Pair u v) ∈ A)
        { refine SigmaD1 (Pair u v) A (λ _, B) (hsubS (Pair u v) huv) };
      refine ind_eq (eq_sym (fst_conv u v)) (λ w, w ∈ A) hfst };
  rewrite Pi_def;
  refine CollectI (cons (Pair c b) f) (Pow (Sigma (cons c A) (λ _, B)))
    (λ g, cons c A ⊆ domain g ∧ function g) _ _
  { refine PowI (cons (Pair c b) f) (Sigma (cons c A) (λ _, B)) _;
    assume p hp;
    refine ∨ₑ (∧ₑ₁ (cons_iff p (Pair c b) f) hp) _ _
    { assume hpeq;
      refine ind_eq hpeq (λ w, w ∈ Sigma (cons c A) (λ _, B))
        (SigmaI c b (cons c A) (λ _, B) (consI1 c A) hbB) }
    { assume hpf;
      refine ∃ₑ (SigmaE p A (λ _, B) (hsubS p hpf)) _;
      assume u hu;
      refine ∃ₑ (∧ₑ₂ hu) _;
      assume v hv;
      refine ind_eq (∧ₑ₂ hv) (λ w, w ∈ Sigma (cons c A) (λ _, B))
        (SigmaI u v (cons c A) (λ _, B) (consI2 u c A (∧ₑ₁ hu)) (∧ₑ₁ hv)) } }
  { apply ∧ᵢ
    { assume u hu;
      refine ∨ₑ (∧ₑ₁ (cons_iff u c A) hu) _ _
      { assume huc;
        refine ind_eq huc (λ w, w ∈ domain (cons (Pair c b) f))
          (domainI c b (cons (Pair c b) f) (consI1 (Pair c b) f)) }
      { assume huA;
        refine ∃ₑ (domainE u f (hAdom u huA)) _;
        assume v hv;
        refine domainI u v (cons (Pair c b) f) (consI2 (Pair u v) (Pair c b) f hv) } }
    { rewrite function_def;
      assume x y yp h1 h2;
      refine ∨ₑ (∧ₑ₁ (cons_iff (Pair x y) (Pair c b) f) h1) _ _
      { assume he1;
        refine ∨ₑ (∧ₑ₁ (cons_iff (Pair x yp) (Pair c b) f) h2) _ _
        { assume he2;
          refine eq_trans (Pair_inject2 x y c b he1) (eq_sym (Pair_inject2 x yp c b he2)) }
        { assume hm2;
          have hxA : π (x ∈ A) { refine hmemD x yp hm2 };
          refine ⊥ₑ (hcA (ind_eq (eq_sym (Pair_inject1 x y c b he1)) (λ w, w ∈ A) hxA)) } }
      { assume hm1;
        refine ∨ₑ (∧ₑ₁ (cons_iff (Pair x yp) (Pair c b) f) h2) _ _
        { assume he2;
          have hxA : π (x ∈ A) { refine hmemD x y hm1 };
          refine ⊥ₑ (hcA (ind_eq (eq_sym (Pair_inject1 x yp c b he2)) (λ w, w ∈ A) hxA)) }
        { assume hm2; refine functionD f hfun x y yp hm1 hm2 } } } }
end;

// restrict_type2 (func.thy): f ∈ C->B ⟹ A ⊆ C ⟹ restrict(f,A) ∈ A->B
private opaque symbol restrict_type2 (f C B A : τ ι) :
  π (f ∈ Pi C (λ _, B)) → π (A ⊆ C) → π (restrict f A ∈ Pi A (λ _, B)) ≔
begin
  assume f C B A hf hsub;
  have hfun : π (function f) { refine Pi_function f C (λ _, B) hf };
  have hsubS : π (f ⊆ Sigma C (λ _, B)) { refine Pi_subset_Sigma f C (λ _, B) hf };
  have hdomeq : π (domain f = C) { refine domain_of_fun f C (λ _, B) hf };
  rewrite Pi_def;
  refine CollectI (restrict f A) (Pow (Sigma A (λ _, B)))
    (λ g, A ⊆ domain g ∧ function g) _ _
  { refine PowI (restrict f A) (Sigma A (λ _, B)) _;
    assume p hp;
    have hpf : π (p ∈ f) { refine restrictD1 p f A hp };
    have hbex : π (Bex A (λ x, `∃ (y : τ ι), p = Pair x y))
      { refine ∧ₑ₂ (restrictE p f A hp) };
    refine ∃ₑ hbex _;
    assume u hu;
    refine ∃ₑ (∧ₑ₂ hu) _;
    assume v hv;
    have hsnd : π (snd p ∈ B) { refine SigmaD2 p C (λ _, B) (hsubS p hpf) };
    have hsnd2 : π (snd (Pair u v) ∈ B) { refine ind_eq (eq_sym hv) (λ w, snd w ∈ B) hsnd };
    have hvB : π (v ∈ B) { refine ind_eq (eq_sym (snd_conv u v)) (λ w, w ∈ B) hsnd2 };
    refine ind_eq hv (λ w, w ∈ Sigma A (λ _, B)) (SigmaI u v A (λ _, B) (∧ₑ₁ hu) hvB) }
  { apply ∧ᵢ
    { assume u hu;
      have hudom : π (u ∈ domain f) { refine ind_eq hdomeq (λ w, u ∈ w) (hsub u hu) };
      have hpair : π (Pair u (fapply f u) ∈ f) { refine apply_Pair f u hfun hudom };
      refine domainI u (fapply f u) (restrict f A)
        (restrictI u (fapply f u) f A hpair hu) }
    { refine function_restrictI f A hfun } }
end;

// fun_cons_restrict_eq (func.thy): f ∈ cons(x,y)->B ⟹ f = cons(⟨x,f`x⟩, restrict(f,y))
private opaque symbol fun_cons_restrict_eq (f x y B : τ ι) :
  π (f ∈ Pi (cons x y) (λ _, B)) →
  π (f = cons (Pair x (fapply f x)) (restrict f y)) ≔
begin
  assume f x y B hf;
  have hfun : π (function f) { refine Pi_function f (cons x y) (λ _, B) hf };
  have hsubS : π (f ⊆ Sigma (cons x y) (λ _, B))
    { refine Pi_subset_Sigma f (cons x y) (λ _, B) hf };
  refine equality_iffI f (cons (Pair x (fapply f x)) (restrict f y)) _;
  assume p;
  apply ∧ᵢ
  { assume hp;
    refine ∃ₑ (SigmaE p (cons x y) (λ _, B) (hsubS p hp)) _;
    assume u hu;
    refine ∃ₑ (∧ₑ₂ hu) _;
    assume v hv;
    have hpeq : π (p = Pair u v) { refine ∧ₑ₂ hv };
    have hpuvf : π (Pair u v ∈ f) { refine ind_eq (eq_sym hpeq) (λ w, w ∈ f) hp };
    refine ∨ₑ (∧ₑ₁ (cons_iff u x y) (∧ₑ₁ hu)) _ _
    { assume hux;
      have hPxv : π (Pair x v ∈ f) { refine ind_eq (eq_sym hux) (λ w, Pair w v ∈ f) hpuvf };
      have happ : π (fapply f x = v) { refine function_apply_equality x v f hPxv hfun };
      have hp2 : π (p = Pair x (fapply f x))
        { rewrite hpeq; rewrite hux; rewrite happ; reflexivity };
      refine ∧ₑ₂ (cons_iff p (Pair x (fapply f x)) (restrict f y)) (∨ᵢ₁ hp2) }
    { assume huy;
      have hres : π (Pair u v ∈ restrict f y) { refine restrictI u v f y hpuvf huy };
      refine consI2 p (Pair x (fapply f x)) (restrict f y)
        (ind_eq hpeq (λ w, w ∈ restrict f y) hres) } }
  { assume hp;
    refine ∨ₑ (∧ₑ₁ (cons_iff p (Pair x (fapply f x)) (restrict f y)) hp) _ _
    { assume hpeq;
      refine ind_eq hpeq (λ w, w ∈ f)
        (Pi_apply_Pair f x (cons x y) (λ _, B) hf (consI1 x y)) }
    { assume hpres; refine restrictD1 p f y hpres } }
end;

// ===========================================================================
// Inductive intro rules (package-generated; not explicit `lemma` lines).
// ===========================================================================

// Fin.emptyI : 0 ∈ Fin(A)
opaque symbol Fin_0I (A : τ ι) :
  π (empty ∈ Fin A) ≔
begin
  assume A;
  have hunf : π (Fin A = Collect (Pow A) (λ z,
      z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ Fin A)))
    { refine lfp_unfold (Pow A) (λ X, Collect (Pow A) (λ z,
        z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ X)))
        (Fin_bnd_mono A) };
  refine ind_eq hunf (λ w, empty ∈ w) _;
  refine CollectI empty (Pow A)
    (λ z, z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), z = cons a b ∧ a ∈ A ∧ b ∈ Fin A))
    (Pow_bottom A) (∨ᵢ₁ (eq_refl empty))
end;

// Fin.consI : ⟦a ∈ A; b ∈ Fin(A)⟧ ⟹ cons(a,b) ∈ Fin(A)
opaque symbol Fin_consI (A a b : τ ι) :
  π (a ∈ A) → π (b ∈ Fin A) → π (cons a b ∈ Fin A) ≔
begin
  assume A a b haA hbF;
  have hsub : π (Fin A ⊆ Pow A)
    { refine lfp_subset (Pow A) (λ X, Collect (Pow A) (λ z,
        z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ A ∧ v ∈ X))) };
  have hbA : π (b ⊆ A) { refine PowD b A (hsub b hbF) };
  have hconsA : π (cons a b ⊆ A)
    { assume w hw;
      refine ∨ₑ (∧ₑ₁ (cons_iff w a b) hw) _ _
      { assume hwa; refine ind_eq hwa (λ v, v ∈ A) haA }
      { assume hwb; refine hbA w hwb } };
  have hunf : π (Fin A = Collect (Pow A) (λ z,
      z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ A ∧ v ∈ Fin A)))
    { refine lfp_unfold (Pow A) (λ X, Collect (Pow A) (λ z,
        z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ A ∧ v ∈ X)))
        (Fin_bnd_mono A) };
  refine ind_eq hunf (λ w, cons a b ∈ w) _;
  refine CollectI (cons a b) (Pow A)
    (λ z, z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ A ∧ v ∈ Fin A))
    (PowI (cons a b) A hconsA)
    (∨ᵢ₂ (∃ᵢ a (∃ᵢ b (∧ᵢ (eq_refl (cons a b)) (∧ᵢ haA hbF)))))
end;

// FiniteFun.emptyI : 0 ∈ A -||> B
opaque symbol FiniteFun_0I (A B : τ ι) :
  π (empty ∈ FiniteFun A B) ≔
begin
  assume A B;
  have hunf : π (FiniteFun A B = Collect (Fin (Sigma A (λ _, B))) (λ z,
      z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
        z = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ FiniteFun A B ∧ a ∉ domain g)))
    { refine lfp_unfold (Fin (Sigma A (λ _, B)))
        (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
          z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
            z = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ X ∧ a ∉ domain g)))
        (FiniteFun_bnd_mono A B) };
  refine ind_eq hunf (λ w, empty ∈ w) _;
  refine CollectI empty (Fin (Sigma A (λ _, B)))
    (λ z, z = empty ∨ (`∃ (a : τ ι), `∃ (b : τ ι), `∃ (g : τ ι),
      z = cons (Pair a b) g ∧ a ∈ A ∧ b ∈ B ∧ g ∈ FiniteFun A B ∧ a ∉ domain g))
    (Fin_0I (Sigma A (λ _, B))) (∨ᵢ₁ (eq_refl empty))
end;

// FiniteFun.consI : ⟦a ∈ A; b ∈ B; h ∈ A -||> B; a ∉ domain(h)⟧
//                   ⟹ cons(⟨a,b⟩, h) ∈ A -||> B
opaque symbol FiniteFun_consI (A B a b h : τ ι) :
  π (a ∈ A) → π (b ∈ B) → π (h ∈ FiniteFun A B) → π (a ∉ domain h) →
  π (cons (Pair a b) h ∈ FiniteFun A B) ≔
begin
  assume A B a b h haA hbB hhF hnd;
  have hsub : π (FiniteFun A B ⊆ Fin (Sigma A (λ _, B)))
    { refine lfp_subset (Fin (Sigma A (λ _, B)))
        (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
          z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
            z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ X ∧ u ∉ domain g))) };
  have hcFin : π (cons (Pair a b) h ∈ Fin (Sigma A (λ _, B)))
    { refine Fin_consI (Sigma A (λ _, B)) (Pair a b) h
        (SigmaI a b A (λ _, B) haA hbB) (hsub h hhF) };
  have hunf : π (FiniteFun A B = Collect (Fin (Sigma A (λ _, B))) (λ z,
      z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
        z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ FiniteFun A B ∧ u ∉ domain g)))
    { refine lfp_unfold (Fin (Sigma A (λ _, B)))
        (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
          z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
            z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ X ∧ u ∉ domain g)))
        (FiniteFun_bnd_mono A B) };
  refine ind_eq hunf (λ w, cons (Pair a b) h ∈ w) _;
  refine CollectI (cons (Pair a b) h) (Fin (Sigma A (λ _, B)))
    (λ z, z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
      z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ FiniteFun A B ∧ u ∉ domain g))
    hcFin
    (∨ᵢ₂ (∃ᵢ a (∃ᵢ b (∃ᵢ h (∧ᵢ (eq_refl (cons (Pair a b) h))
      (∧ᵢ haA (∧ᵢ hbB (∧ᵢ hhF hnd))))))))
end;

// FiniteFun.induct (package-generated): structural induction on A -||> B.
opaque symbol FiniteFun_induct (A B f : τ ι) (P : τ ι → Prop) :
  π (f ∈ FiniteFun A B) →
  π (P empty) →
  (Π (a b h : τ ι), π (a ∈ A) → π (b ∈ B) → π (h ∈ FiniteFun A B) →
    π (a ∉ domain h) → π (P h) → π (P (cons (Pair a b) h))) →
  π (P f) ≔
begin
  assume A B f P hf h0 hstep;
  refine lfp_induct_raw (Fin (Sigma A (λ _, B))) f
    (λ X, Collect (Fin (Sigma A (λ _, B))) (λ z,
      z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
        z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ X ∧ u ∉ domain g)))
    P hf (FiniteFun_bnd_mono A B) _;
  assume x hx;
  have hd : π (x = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
      x = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ Collect (FiniteFun A B) P ∧ u ∉ domain g))
    { refine CollectD2 x (Fin (Sigma A (λ _, B)))
        (λ z, z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), `∃ (g : τ ι),
          z = cons (Pair u v) g ∧ u ∈ A ∧ v ∈ B ∧ g ∈ Collect (FiniteFun A B) P ∧ u ∉ domain g)) hx };
  refine ∨ₑ hd _ _
  { assume hxe; refine ind_eq hxe P h0 }
  { assume hex;
    refine ∃ₑ hex _;
    assume u hu;
    refine ∃ₑ hu _;
    assume v hv;
    refine ∃ₑ hv _;
    assume g hg;
    have hgC : π (g ∈ Collect (FiniteFun A B) P)
      { refine ∧ₑ₁ (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ hg))) };
    refine ind_eq (∧ₑ₁ hg) P _;
    refine hstep u v g (∧ₑ₁ (∧ₑ₂ hg)) (∧ₑ₁ (∧ₑ₂ (∧ₑ₂ hg)))
      (CollectD1 g (FiniteFun A B) P hgC)
      (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ (∧ₑ₂ hg))))
      (CollectD2 g (FiniteFun A B) P hgC) }
end;

// ===========================================================================
// Finite Powerset Operator
// ===========================================================================

// FinD : A ∈ Fin(B) ⟹ A ⊆ B   [lemmas FinD = Fin.dom_subset [THEN subsetD, THEN PowD]]
opaque symbol FinD (A B : τ ι) :
  π (A ∈ Fin B) → π (A ⊆ B) ≔
begin
  assume A B h;
  refine PowD A B (lfp_subset (Pow B) (λ X, Collect (Pow B) (λ z,
      z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ B ∧ v ∈ X)))
    A h)
end;

// Fin_induct : induction on finite sets.  Isabelle derives it from the raw
// Fin.induct by discharging the extra x∉y hypothesis via cons_absorb.
opaque symbol Fin_induct (A b : τ ι) (P : τ ι → Prop) :
  π (b ∈ Fin A) →
  π (P empty) →
  (Π (x y : τ ι), π (x ∈ A) → π (y ∈ Fin A) → π (x ∉ y) → π (P y) → π (P (cons x y))) →
  π (P b) ≔
begin
  assume A b P hb h0 hstep;
  refine lfp_induct_raw (Pow A) b
    (λ X, Collect (Pow A) (λ z,
      z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι), z = cons u v ∧ u ∈ A ∧ v ∈ X)))
    P hb (Fin_bnd_mono A) _;
  assume x hx;
  have hd : π (x = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι),
      x = cons u v ∧ u ∈ A ∧ v ∈ Collect (Fin A) P))
    { refine CollectD2 x (Pow A)
        (λ z, z = empty ∨ (`∃ (u : τ ι), `∃ (v : τ ι),
          z = cons u v ∧ u ∈ A ∧ v ∈ Collect (Fin A) P)) hx };
  refine ∨ₑ hd _ _
  { assume hxe; refine ind_eq hxe P h0 }
  { assume hex;
    refine ∃ₑ hex _;
    assume u hu;
    refine ∃ₑ hu _;
    assume v hv;
    have hvC : π (v ∈ Collect (Fin A) P) { refine ∧ₑ₂ (∧ₑ₂ hv) };
    have hvF : π (v ∈ Fin A) { refine CollectD1 v (Fin A) P hvC };
    have hPv : π (P v) { refine CollectD2 v (Fin A) P hvC };
    refine ind_eq (∧ₑ₁ hv) P _;
    refine ∨ₑ (em (u ∈ v)) _ _
    { assume huv; refine ind_eq (cons_absorb u v huv) P hPv }
    { assume hnuv; refine hstep u v (∧ₑ₁ (∧ₑ₂ hv)) hvF hnuv hPv } }
end;

// Fin_mono : A ⊆ B ⟹ Fin(A) ⊆ Fin(B)
opaque symbol Fin_mono (A B : τ ι) :
  π (A ⊆ B) → π (Fin A ⊆ Fin B) ≔
begin
  assume A B hAB C hC;
  refine Fin_induct A C (λ w, w ∈ Fin B) hC _ _
  { refine Fin_0I B }
  { assume x y hxA hyFinA hxny hyFinB;
    refine Fin_consI B x y (hAB x hxA) hyFinB }
end;

// Fin_0 : Fin(0) = {0}
opaque symbol Fin_0 :
  π (Fin empty = singleton empty) ≔
begin
  refine equality_iffI (Fin empty) (singleton empty) _;
  assume C;
  apply ∧ᵢ
  { assume hC;
    // C ∈ Fin(0) → C ⊆ 0 → C = 0.
    refine ∧ₑ₂ (singleton_iff C empty) (subset_empty C (FinD C empty hC)) }
  { assume hC;
    // C ∈ {0} → C = 0 → C ∈ Fin(0).
    refine ind_eq (∧ₑ₁ (singleton_iff C empty) hC) (λ w, w ∈ Fin empty) (Fin_0I empty) }
end;

// Fin_UnI : ⟦b ∈ Fin(A); c ∈ Fin(A)⟧ ⟹ b ∪ c ∈ Fin(A)
opaque symbol Fin_UnI (A b c : τ ι) :
  π (b ∈ Fin A) → π (c ∈ Fin A) → π (Un b c ∈ Fin A) ≔
begin
  assume A b c hb hc;
  refine Fin_induct A b (λ w, Un w c ∈ Fin A) hb _ _
  { refine ind_eq (Un_empty_left c) (λ w, w ∈ Fin A) hc }
  { assume x y hxA hyFinA hxny hyUn;
    refine ind_eq (cons_Un_distrib x y c) (λ w, w ∈ Fin A)
      (Fin_consI A x (Un y c) hxA hyUn) }
end;

// Fin_UnionI : C ∈ Fin(Fin(A)) ⟹ ⋃(C) ∈ Fin(A)
opaque symbol Fin_UnionI (A C : τ ι) :
  π (C ∈ Fin (Fin A)) → π (Union C ∈ Fin A) ≔
begin
  assume A C hC;
  refine Fin_induct (Fin A) C (λ w, Union w ∈ Fin A) hC _ _
  { refine ind_eq Union_empty (λ w, w ∈ Fin A) (Fin_0I A) }
  { assume x y hxF hyFF hxny hU;
    refine ind_eq (Union_cons x y) (λ w, w ∈ Fin A) (Fin_UnI A x (Union y) hxF hU) }
end;

// Fin_subset_lemma [rule_format] : b ∈ Fin(A) ⟹ ∀z. z ⊆ b ⟶ z ∈ Fin(A)
opaque symbol Fin_subset_lemma (A b : τ ι) :
  π (b ∈ Fin A) → π (`∀ (z : τ ι), z ⊆ b ⇒ z ∈ Fin A) ≔
begin
  assume A b hb;
  refine Fin_induct A b (λ w, `∀ (z : τ ι), z ⊆ w ⇒ z ∈ Fin A) hb _ _
  { assume z hz;
    refine ind_eq (subset_empty z hz) (λ w, w ∈ Fin A) (Fin_0I A) }
  { assume x y hxA hyF hxny hIH z hsub;
    refine ∨ₑ (em (x ∈ z)) _ _
    { assume hxz;
      // z = cons(x, z - {x}) with z - {x} ⊆ y
      have hz'y : π (Diff z (singleton x) ⊆ y)
        { assume w hw;
          have hwz : π (w ∈ z) { refine DiffD1 w z (singleton x) hw };
          have hwns : π (w ∉ singleton x) { refine DiffD2 w z (singleton x) hw };
          refine ∨ₑ (∧ₑ₁ (cons_iff w x y) (hsub w hwz)) _ _
          { assume hwx; refine ⊥ₑ (hwns (∧ₑ₂ (singleton_iff w x) hwx)) }
          { assume hwy; refine hwy } };
      have hcons : π (cons x (Diff z (singleton x)) ∈ Fin A)
        { refine Fin_consI A x (Diff z (singleton x)) hxA
            (hIH (Diff z (singleton x)) hz'y) };
      refine ind_eq (eq_sym (cons_Diff x z hxz)) (λ w, w ∈ Fin A) hcons }
    { assume hnxz;
      have hzy : π (z ⊆ y)
        { assume w hw;
          refine ∨ₑ (∧ₑ₁ (cons_iff w x y) (hsub w hw)) _ _
          { assume hwx;
            refine ⊥ₑ (hnxz (ind_eq (eq_sym hwx) (λ v, v ∈ z) hw)) }
          { assume hwy; refine hwy } };
      refine hIH z hzy } }
end;

// Fin_subset : ⟦c ⊆ b; b ∈ Fin(A)⟧ ⟹ c ∈ Fin(A)
opaque symbol Fin_subset (A b c : τ ι) :
  π (c ⊆ b) → π (b ∈ Fin A) → π (c ∈ Fin A) ≔
begin
  assume A b c hcb hb;
  refine Fin_subset_lemma A b hb c hcb
end;

// Fin_IntI1 : b ∈ Fin(A) ⟹ b ∩ c ∈ Fin(A)
opaque symbol Fin_IntI1 (A b c : τ ι) :
  π (b ∈ Fin A) → π (Int b c ∈ Fin A) ≔
begin
  assume A b c hb;
  refine Fin_subset A b (Int b c) (Int_lower1 b c) hb
end;

// Fin_IntI2 : c ∈ Fin(A) ⟹ b ∩ c ∈ Fin(A)
opaque symbol Fin_IntI2 (A b c : τ ι) :
  π (c ∈ Fin A) → π (Int b c ∈ Fin A) ≔
begin
  assume A b c hc;
  refine Fin_subset A c (Int b c) (Int_lower2 b c) hc
end;

// Fin_0_induct_lemma [rule_format] :
//   ⟦c ∈ Fin(A); b ∈ Fin(A); P(b);
//      ⋀x y. ⟦x ∈ A; y ∈ Fin(A); x ∈ y; P(y)⟧ ⟹ P(y-{x})⟧
//   ⟹ c ⊆ b ⟶ P(b-c)
opaque symbol Fin_0_induct_lemma (A b c : τ ι) (P : τ ι → Prop) :
  π (c ∈ Fin A) →
  π (b ∈ Fin A) →
  π (P b) →
  (Π (x y : τ ι), π (x ∈ A) → π (y ∈ Fin A) → π (x ∈ y) → π (P y) → π (P (Diff y (singleton x)))) →
  π (c ⊆ b ⇒ P (Diff b c)) ≔
begin
  assume A b c P hc hb hPb hstep;
  refine Fin_induct A c (λ w, w ⊆ b ⇒ P (Diff b w)) hc _ _
  { assume h0;
    refine ind_eq (Diff_empty b) P hPb }
  { assume x y hxA hyF hxny hIH hsub;
    have hyb : π (y ⊆ b) { assume w hw; refine hsub w (consI2 w x y hw) };
    have hxb : π (x ∈ b) { refine hsub x (consI1 x y) };
    have hDbyF : π (Diff b y ∈ Fin A)
      { refine Fin_subset A b (Diff b y) (Diff_subset b y) hb };
    have hstep' : π (P (Diff (Diff b y) (singleton x)))
      { refine hstep x (Diff b y) hxA hDbyF (DiffI x b y hxb hxny) (hIH hyb) };
    refine ind_eq (Diff_cons_eq b x y) P hstep' }
end;

// Fin_0_induct :
//   ⟦b ∈ Fin(A); P(b);
//      ⋀x y. ⟦x ∈ A; y ∈ Fin(A); x ∈ y; P(y)⟧ ⟹ P(y-{x})⟧ ⟹ P(0)
opaque symbol Fin_0_induct (A b : τ ι) (P : τ ι → Prop) :
  π (b ∈ Fin A) →
  π (P b) →
  (Π (x y : τ ι), π (x ∈ A) → π (y ∈ Fin A) → π (x ∈ y) → π (P y) → π (P (Diff y (singleton x)))) →
  π (P empty) ≔
begin
  assume A b P hb hPb hstep;
  have h1 : π (P (Diff b b))
    { refine Fin_0_induct_lemma A b b P hb hb hPb hstep (subset_refl b) };
  refine ind_eq (eq_sym (Diff_cancel b)) P h1
end;

// Every natural number is a finite subset of nat.
private opaque symbol nat_into_Fin (n : τ ι) :
  π (n ∈ omega) → π (n ∈ Fin omega) ≔
begin
  assume n hn;
  refine nat_induct (λ m, m ∈ Fin omega) (Fin_0I omega) _ n hn;
  assume m hm hmF;
  rewrite succ_def;
  refine Fin_consI omega m m hm hmF
end;

// A function on a finite domain b ⊆ X is a finite subset of X*A.
private opaque symbol fun_subset_Fin (b X A : τ ι) :
  π (b ∈ Fin X) →
  π (`∀ (f : τ ι), f ∈ Pi b (λ _, A) ⇒ f ∈ Fin (Sigma X (λ _, A))) ≔
begin
  assume b X A hb;
  refine Fin_induct X b
    (λ w, `∀ (f : τ ι), f ∈ Pi w (λ _, A) ⇒ f ∈ Fin (Sigma X (λ _, A))) hb _ _
  { assume f hf;
    refine ind_eq (fun_empty_eq f (λ _, A) hf) (λ w, w ∈ Fin (Sigma X (λ _, A)))
      (Fin_0I (Sigma X (λ _, A))) }
  { assume x y hxX hyF hxny hIH f hf;
    have hysub : π (y ⊆ cons x y) { assume w hw; refine consI2 w x y hw };
    have hres : π (restrict f y ∈ Pi y (λ _, A))
      { refine restrict_type2 f (cons x y) A y hf hysub };
    have hfx : π (fapply f x ∈ A)
      { refine fapply_type f x (cons x y) (λ _, A) hf (consI1 x y) };
    have hcons : π (cons (Pair x (fapply f x)) (restrict f y) ∈ Fin (Sigma X (λ _, A)))
      { refine Fin_consI (Sigma X (λ _, A)) (Pair x (fapply f x)) (restrict f y)
          (SigmaI x (fapply f x) X (λ _, A) hxX hfx) (hIH (restrict f y) hres) };
    refine ind_eq (fun_cons_restrict_eq f x y A hf)
      (λ w, w ∈ Fin (Sigma X (λ _, A))) hcons }
end;

// nat_fun_subset_Fin : n ∈ nat ⟹ n->A ⊆ Fin(nat*A)
opaque symbol nat_fun_subset_Fin (n A : τ ι) :
  π (n ∈ omega) → π (Pi n (λ _, A) ⊆ Fin (Sigma omega (λ _, A))) ≔
begin
  assume n A hn f hf;
  refine fun_subset_Fin n omega A (nat_into_Fin n hn) f hf
end;

// ===========================================================================
// Finite Function Space
// ===========================================================================

// FiniteFun_mono : ⟦A ⊆ C; B ⊆ D⟧ ⟹ A -||> B ⊆ C -||> D
opaque symbol FiniteFun_mono (A B C D : τ ι) :
  π (A ⊆ C) → π (B ⊆ D) → π (FiniteFun A B ⊆ FiniteFun C D) ≔
begin
  assume A B C D hAC hBD w hw;
  refine FiniteFun_induct A B w (λ v, v ∈ FiniteFun C D) hw _ _
  { refine FiniteFun_0I C D }
  { assume a b g haA hbB hgF hnd hIH;
    refine FiniteFun_consI C D a b g (hAC a haA) (hBD b hbB) hIH hnd }
end;

// FiniteFun_mono1 : A ⊆ B ⟹ A -||> A ⊆ B -||> B
opaque symbol FiniteFun_mono1 (A B : τ ι) :
  π (A ⊆ B) → π (FiniteFun A A ⊆ FiniteFun B B) ≔
begin
  assume A B hAB;
  refine FiniteFun_mono A A B B hAB hAB
end;

// FiniteFun_is_fun : h ∈ A -||> B ⟹ h ∈ domain(h) -> B
opaque symbol FiniteFun_is_fun (A B h : τ ι) :
  π (h ∈ FiniteFun A B) → π (h ∈ Pi (domain h) (λ _, B)) ≔
begin
  assume A B h hh;
  refine FiniteFun_induct A B h (λ w, w ∈ Pi (domain w) (λ _, B)) hh _ _
  { refine ind_eq domain_empty (λ w, empty ∈ Pi w (λ _, B)) (empty_funI (λ _, B)) }
  { assume a b g haA hbB hgF hnd hIH;
    have hext : π (cons (Pair a b) g ∈ Pi (cons a (domain g)) (λ _, B))
      { refine fun_extend3 g (domain g) B a b hIH hnd hbB };
    refine ind_eq (domain_cons a b g) (λ w, cons (Pair a b) g ∈ Pi w (λ _, B)) hext }
end;

// FiniteFun_domain_Fin : h ∈ A -||> B ⟹ domain(h) ∈ Fin(A)
opaque symbol FiniteFun_domain_Fin (A B h : τ ι) :
  π (h ∈ FiniteFun A B) → π (domain h ∈ Fin A) ≔
begin
  assume A B h hh;
  refine FiniteFun_induct A B h (λ w, domain w ∈ Fin A) hh _ _
  { refine ind_eq domain_empty (λ w, w ∈ Fin A) (Fin_0I A) }
  { assume a b g haA hbB hgF hnd hIH;
    refine ind_eq (domain_cons a b g) (λ w, w ∈ Fin A)
      (Fin_consI A a (domain g) haA hIH) }
end;

// FiniteFun_apply_type : ⟦h ∈ A -||> B; a ∈ domain(h)⟧ ⟹ h`a ∈ B
//   [lemmas FiniteFun_apply_type = FiniteFun_is_fun [THEN apply_type]]
opaque symbol FiniteFun_apply_type (A B h a : τ ι) :
  π (h ∈ FiniteFun A B) → π (a ∈ domain h) → π (fapply h a ∈ B) ≔
begin
  assume A B h a hh ha;
  refine fapply_type h a (domain h) (λ _, B) (FiniteFun_is_fun A B h hh) ha
end;

// FiniteFun_subset_lemma [rule_format] : b ∈ A -||> B ⟹ ∀z. z ⊆ b ⟶ z ∈ A -||> B
opaque symbol FiniteFun_subset_lemma (A B b : τ ι) :
  π (b ∈ FiniteFun A B) → π (`∀ (z : τ ι), z ⊆ b ⇒ z ∈ FiniteFun A B) ≔
begin
  assume A B b hb;
  refine FiniteFun_induct A B b (λ w, `∀ (z : τ ι), z ⊆ w ⇒ z ∈ FiniteFun A B) hb _ _
  { assume z hz;
    refine ind_eq (subset_empty z hz) (λ w, w ∈ FiniteFun A B) (FiniteFun_0I A B) }
  { assume a v g haA hvB hgF hnd hIH z hsub;
    refine ∨ₑ (em (Pair a v ∈ z)) _ _
    { assume hin;
      // z = cons(⟨a,v⟩, z - {⟨a,v⟩}) with z - {⟨a,v⟩} ⊆ g
      have hz'g : π (Diff z (singleton (Pair a v)) ⊆ g)
        { assume w hw;
          have hwz : π (w ∈ z) { refine DiffD1 w z (singleton (Pair a v)) hw };
          have hwns : π (w ∉ singleton (Pair a v))
            { refine DiffD2 w z (singleton (Pair a v)) hw };
          refine ∨ₑ (∧ₑ₁ (cons_iff w (Pair a v) g) (hsub w hwz)) _ _
          { assume hweq; refine ⊥ₑ (hwns (∧ₑ₂ (singleton_iff w (Pair a v)) hweq)) }
          { assume hwg; refine hwg } };
      have hz'F : π (Diff z (singleton (Pair a v)) ∈ FiniteFun A B)
        { refine hIH (Diff z (singleton (Pair a v))) hz'g };
      have hnd' : π (a ∉ domain (Diff z (singleton (Pair a v))))
        { assume hda;
          refine hnd (domain_mono (Diff z (singleton (Pair a v))) g hz'g a hda) };
      have hcons : π (cons (Pair a v) (Diff z (singleton (Pair a v))) ∈ FiniteFun A B)
        { refine FiniteFun_consI A B a v (Diff z (singleton (Pair a v)))
            haA hvB hz'F hnd' };
      refine ind_eq (eq_sym (cons_Diff (Pair a v) z hin))
        (λ w, w ∈ FiniteFun A B) hcons }
    { assume hnin;
      have hzg : π (z ⊆ g)
        { assume w hw;
          refine ∨ₑ (∧ₑ₁ (cons_iff w (Pair a v) g) (hsub w hw)) _ _
          { assume hweq;
            refine ⊥ₑ (hnin (ind_eq (eq_sym hweq) (λ u, u ∈ z) hw)) }
          { assume hwg; refine hwg } };
      refine hIH z hzg } }
end;

// FiniteFun_subset : ⟦c ⊆ b; b ∈ A -||> B⟧ ⟹ c ∈ A -||> B
opaque symbol FiniteFun_subset (A B b c : τ ι) :
  π (c ⊆ b) → π (b ∈ FiniteFun A B) → π (c ∈ FiniteFun A B) ≔
begin
  assume A B b c hcb hb;
  refine FiniteFun_subset_lemma A B b hb c hcb
end;

// fun_FiniteFunI [rule_format] : A ∈ Fin(X) ⟹ ∀f. f ∈ A->B ⟶ f ∈ A -||> B
opaque symbol fun_FiniteFunI (A B X : τ ι) :
  π (A ∈ Fin X) → π (`∀ (f : τ ι), f ∈ Pi A (λ _, B) ⇒ f ∈ FiniteFun A B) ≔
begin
  assume A B X hA;
  refine Fin_induct X A (λ w, `∀ (f : τ ι), f ∈ Pi w (λ _, B) ⇒ f ∈ FiniteFun w B) hA _ _
  { assume f hf;
    refine ind_eq (fun_empty_eq f (λ _, B) hf) (λ w, w ∈ FiniteFun empty B)
      (FiniteFun_0I empty B) }
  { assume x y hxX hyF hxny hIH f hf;
    have hysub : π (y ⊆ cons x y) { assume w hw; refine consI2 w x y hw };
    have hres : π (restrict f y ∈ Pi y (λ _, B))
      { refine restrict_type2 f (cons x y) B y hf hysub };
    have hresFF : π (restrict f y ∈ FiniteFun (cons x y) B)
      { refine FiniteFun_mono y B (cons x y) B hysub (subset_refl B)
          (restrict f y) (hIH (restrict f y) hres) };
    have hfx : π (fapply f x ∈ B)
      { refine fapply_type f x (cons x y) (λ _, B) hf (consI1 x y) };
    have hnd : π (x ∉ domain (restrict f y))
      { assume hd; refine hxny (domain_restrict_sub f y x hd) };
    have hcons : π (cons (Pair x (fapply f x)) (restrict f y) ∈ FiniteFun (cons x y) B)
      { refine FiniteFun_consI (cons x y) B x (fapply f x) (restrict f y)
          (consI1 x y) hfx hresFF hnd };
    refine ind_eq (fun_cons_restrict_eq f x y B hf)
      (λ w, w ∈ FiniteFun (cons x y) B) hcons }
end;

// lam_FiniteFun : A ∈ Fin(X) ⟹ (λx∈A. b(x)) ∈ A -||> {b(x). x ∈ A}
opaque symbol lam_FiniteFun (A X : τ ι) (b : τ ι → τ ι) :
  π (A ∈ Fin X) → π (Lambda A (λ x, b x) ∈ FiniteFun A (RepFun A (λ x, b x))) ≔
begin
  assume A X b hA;
  have hball : π (Ball A (λ x, b x ∈ RepFun A (λ w, b w)))
    { assume x hx; refine RepFunI x A (λ w, b w) hx };
  have hlam : π (Lambda A (λ x, b x) ∈ Pi A (λ _, RepFun A (λ x, b x)))
    { refine lam_type A (λ x, b x) (λ _, RepFun A (λ x, b x)) hball };
  refine fun_FiniteFunI A (RepFun A (λ x, b x)) X hA (Lambda A (λ x, b x)) hlam
end;

// FiniteFun_Collect_iff :
//   f ∈ FiniteFun(A, {y ∈ B. P(y)})
//     ⟷ f ∈ FiniteFun(A,B) ∧ (∀x∈domain(f). P(f`x))
opaque symbol FiniteFun_Collect_iff (A B f : τ ι) (P : τ ι → Prop) :
  π (f ∈ FiniteFun A (Collect B (λ y, P y)) ⇔
     (f ∈ FiniteFun A B ∧ Ball (domain f) (λ x, P (fapply f x)))) ≔
begin
  assume A B f P;
  apply ∧ᵢ
  { assume hf;
    apply ∧ᵢ
    { refine FiniteFun_mono A (Collect B (λ y, P y)) A B
        (subset_refl A) (Collect_subset B (λ y, P y)) f hf }
    { assume x hx;
      refine CollectD2 (fapply f x) B (λ y, P y)
        (FiniteFun_apply_type A (Collect B (λ y, P y)) f x hf hx) } }
  { assume hconj;
    have hf : π (f ∈ FiniteFun A B) { refine ∧ₑ₁ hconj };
    have hball : π (Ball (domain f) (λ x, P (fapply f x))) { refine ∧ₑ₂ hconj };
    have hisfun : π (f ∈ Pi (domain f) (λ _, B)) { refine FiniteFun_is_fun A B f hf };
    have hfun : π (function f) { refine Pi_function f (domain f) (λ _, B) hisfun };
    have hsubS : π (f ⊆ Sigma (domain f) (λ _, B))
      { refine Pi_subset_Sigma f (domain f) (λ _, B) hisfun };
    // f is also a function into {y ∈ B | P(y)}: every value satisfies P.
    have hsubS2 : π (f ⊆ Sigma (domain f) (λ _, Collect B (λ y, P y)))
      { assume p hp;
        refine ∃ₑ (SigmaE p (domain f) (λ _, B) (hsubS p hp)) _;
        assume u hu;
        refine ∃ₑ (∧ₑ₂ hu) _;
        assume v hv;
        have hpeq : π (p = Pair u v) { refine ∧ₑ₂ hv };
        have hpf : π (Pair u v ∈ f) { refine ind_eq (eq_sym hpeq) (λ w, w ∈ f) hp };
        have happ : π (fapply f u = v) { refine function_apply_equality u v f hpf hfun };
        have hPv : π (P v) { refine ind_eq (eq_sym happ) (λ w, P w) (hball u (∧ₑ₁ hu)) };
        refine ind_eq hpeq (λ w, w ∈ Sigma (domain f) (λ _, Collect B (λ y, P y)))
          (SigmaI u v (domain f) (λ _, Collect B (λ y, P y)) (∧ₑ₁ hu)
            (CollectI v B (λ y, P y) (∧ₑ₁ hv) hPv)) };
    have hPi2 : π (f ∈ Pi (domain f) (λ _, Collect B (λ y, P y)))
      { rewrite Pi_def;
        refine CollectI f (Pow (Sigma (domain f) (λ _, Collect B (λ y, P y))))
          (λ g, domain f ⊆ domain g ∧ function g)
          (PowI f (Sigma (domain f) (λ _, Collect B (λ y, P y))) hsubS2)
          (∧ᵢ (subset_refl (domain f)) hfun) };
    have hdomFin : π (domain f ∈ Fin A) { refine FiniteFun_domain_Fin A B f hf };
    have hFF2 : π (f ∈ FiniteFun (domain f) (Collect B (λ y, P y)))
      { refine fun_FiniteFunI (domain f) (Collect B (λ y, P y)) A hdomFin f hPi2 };
    refine FiniteFun_mono (domain f) (Collect B (λ y, P y)) A (Collect B (λ y, P y))
      (FinD (domain f) A hdomFin) (subset_refl (Collect B (λ y, P y))) f hFF2 }
end;

// ===========================================================================
// The Contents of a Singleton Set
// ===========================================================================

// contents_eq : contents({x}) = x
opaque symbol contents_eq (x : τ ι) :
  π (contents (singleton x) = x) ≔
begin
  assume x;
  refine the_equality (λ y, singleton x = singleton y) x (eq_refl (singleton x)) _;
  assume y hy;
  refine eq_sym (singleton_inject x y hy)
end;
